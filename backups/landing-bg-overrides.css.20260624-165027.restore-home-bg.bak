body::before {
  content: none !important;
}

.hero {
  background-image: none !important;
}

.hero-shade {
  background: linear-gradient(
    90deg,
    rgba(1, 4, 8, 0.92) 0%,
    rgba(1, 4, 8, 0.74) 48%,
    rgba(1, 4, 8, 0.42) 100%
  ) !important;
  backdrop-filter: blur(1px);
}

.section {
  background: rgba(5, 14, 24, 0.58);
  backdrop-filter: blur(8px);
}

.flow-grid,
.feature-card,
.experience-list,
.case-grid article,
.final-cta,
footer {
  background: rgba(5, 14, 24, 0.72) !important;
  backdrop-filter: blur(8px);
}

.button {
  background: rgba(9, 19, 27, 0.82);
  backdrop-filter: blur(8px);
}

.button.primary {
  background: var(--cyan);
}

.button.gold {
  background: rgba(21, 16, 6, 0.82);
}

@media (max-width: 760px) {
  .hero {
    background-image: none !important;
  }
}
