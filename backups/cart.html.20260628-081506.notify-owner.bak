<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>장바구니 | IRIS MAPPING LAB</title>
  <link rel="stylesheet" href="site-navigation.css?v=20260623-fantasy-bg-1">
  <style>
    :root{color-scheme:dark;--bg:#05090f;--panel:#0a1420;--line:#25495d;--text:#f5f7fa;--muted:#9db0bd;--cyan:#38d9d2;--gold:#e7b74e}
    *{box-sizing:border-box}
    body{margin:0;background:linear-gradient(180deg,#07131c,#030609);color:var(--text);font-family:Arial,"Noto Sans KR",sans-serif}
    .page{width:min(980px,100%);margin:auto;padding:24px}
    .kicker{color:var(--cyan);font-size:12px;font-weight:900;letter-spacing:.08em}
    h1{margin:8px 0 18px;font-size:clamp(30px,5vw,44px)}
    h2,h3,p{margin-top:0}
    p{line-height:1.55}
    .card{margin-top:14px;padding:20px;border:1px solid var(--line);border-radius:8px;background:rgba(9,20,32,.95)}
    .cart-list{display:grid;gap:10px}
    .cart-item{display:grid;grid-template-columns:92px minmax(0,1fr) auto;gap:14px;align-items:center;padding:13px;border:1px solid #31566b;border-radius:8px;background:#08121d}
    .thumb{width:92px;aspect-ratio:1;border:1px solid #31566b;border-radius:7px;background:linear-gradient(145deg,#132435,#060b12);object-fit:cover}
    .thumb.is-camera{position:relative}
    .thumb.is-camera::before{content:"";width:54%;height:54%;position:absolute;left:23%;top:23%;border:5px solid #1b4256;border-radius:50%;background:radial-gradient(circle,#030509 0 29%,#2cc7c6 31% 35%,#07121c 37% 59%,#d6aa4c 61% 64%,#06101a 66%)}
    .item-title{display:block;margin-bottom:6px;font-size:18px}
    .muted{color:var(--muted)}
    .price{color:var(--gold);font-weight:900;white-space:nowrap}
    .button{display:inline-flex;align-items:center;justify-content:center;min-height:42px;padding:0 15px;border:1px solid var(--cyan);border-radius:6px;background:var(--cyan);color:#061414;font-weight:900;text-decoration:none;cursor:pointer}
    .ghost{background:#07111b;color:var(--text);border-color:#31566b}
    .danger{background:#12090b;color:#ffd8d8;border-color:#6a3440}
    .actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px}
    .bank{border-color:#755b19;background:linear-gradient(135deg,rgba(231,183,78,.14),rgba(8,18,29,.95))}
    .bank strong{color:var(--gold)}
    .total{display:flex;justify-content:space-between;gap:16px;align-items:center;font-size:22px;font-weight:900}
    .empty{padding:24px;border:1px dashed #31566b;border-radius:8px;color:var(--muted);text-align:center}
    @media(max-width:720px){.page{padding:13px}.cart-item{grid-template-columns:70px minmax(0,1fr);align-items:start}.thumb{width:70px}.price{grid-column:1/-1}.total{display:grid;font-size:18px}}
  </style>
</head>
<body>
<main class="page">
  <span class="kicker">SHOPPING CART</span>
  <h1>장바구니</h1>
  <section class="card">
    <div id="cartList" class="cart-list"></div>
  </section>
  <section class="card bank">
    <h2>입금 안내</h2>
    <p>결제 기능은 사용하지 않습니다. 주문 상품을 확인한 뒤 아래 계좌로 입금해 주세요.</p>
    <p><strong>카카오뱅크 3333-04-9698210 이고은</strong></p>
    <p class="muted">입금 후 상담요청 또는 연락처로 입금자명과 주문 상품을 알려주세요.</p>
  </section>
  <section class="card total">
    <span>총 상품 금액</span>
    <span id="cartTotal" class="price">0원</span>
  </section>
  <div class="actions">
    <a class="button" href="shopping.html">쇼핑 계속하기</a>
    <button id="clearCart" class="button danger" type="button">장바구니 비우기</button>
  </div>
</main>
<script>
  const CART_KEY="irisShoppingCart";
  renderCart();
  document.querySelector("#clearCart").addEventListener("click",()=>{localStorage.removeItem(CART_KEY);renderCart();});
  document.addEventListener("click",(event)=>{
    const remove=event.target.closest("[data-remove]");
    if(!remove)return;
    const cart=readCart().filter((item)=>item.productId!==remove.dataset.remove);
    localStorage.setItem(CART_KEY,JSON.stringify(cart));
    renderCart();
  });
  function renderCart(){
    const cart=readCart();
    const list=document.querySelector("#cartList");
    if(!cart.length){
      list.innerHTML='<div class="empty">장바구니에 담긴 상품이 없습니다.</div>';
      document.querySelector("#cartTotal").textContent="0원";
      return;
    }
    list.innerHTML=cart.map((item)=>`
      <article class="cart-item">
        ${item.imageUrl?`<img class="thumb" src="${escapeHtml(item.imageUrl)}" alt="${escapeHtml(item.name)}">`:`<div class="thumb is-camera" aria-hidden="true"></div>`}
        <div>
          <strong class="item-title">${escapeHtml(item.name)}</strong>
          <p class="muted">${escapeHtml(item.description||item.reason||"상품 설명이 등록되어 있습니다.")}</p>
          <button class="button ghost" type="button" data-remove="${escapeHtml(item.productId)}">삭제</button>
        </div>
        <div class="price">${Number(item.salePrice||0).toLocaleString("ko-KR")}원 × ${Number(item.quantity||1)}</div>
      </article>`).join("");
    const total=cart.reduce((sum,item)=>sum+Number(item.salePrice||0)*Number(item.quantity||1),0);
    document.querySelector("#cartTotal").textContent=total.toLocaleString("ko-KR")+"원";
  }
  function readCart(){try{return JSON.parse(localStorage.getItem(CART_KEY)||"[]")}catch(_){return[]}}
  function escapeHtml(value){return String(value??"").replace(/[&<>"']/g,(char)=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[char]))}
</script>
<script src="site-navigation.js?v=20260624-nav-order-1"></script>
</body>
</html>
