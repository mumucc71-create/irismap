{
  "name": "iris-mapping-lab",
  "version": "1.0.0",
  "private": true,
  "description": "IRIS MAPPING LAB Android wrapper",
  "scripts": {
    "android:prepare": "node tools/prepare-capacitor-web.js",
    "android:sync": "pnpm android:prepare && cap sync android",
