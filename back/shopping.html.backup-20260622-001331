<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>쇼핑하기 | IRIS MAPPING LAB</title>
  <style>
    :root{color-scheme:dark;--bg:#05090f;--panel:#0b1420;--line:#24475b;--text:#f5f7fa;--muted:#9db0bd;--cyan:#36d8d0;--gold:#e7b74e}*{box-sizing:border-box}body{margin:0;background:linear-gradient(180deg,#07121b,#030609);color:var(--text);font-family:Arial,"Noto Sans KR",sans-serif}.page{width:min(1180px,100%);margin:auto;padding:22px}header{display:flex;justify-content:space-between;align-items:center;gap:18px;padding:18px 0 22px;border-bottom:1px solid var(--line)}.brand,.section-kicker{color:var(--cyan);font-size:12px;font-weight:800;letter-spacing:.08em}h1{margin:7px 0 0;font-size:clamp(28px,4vw,42px)}h2{margin:0 0 14px}h3{margin:0 0 8px;color:var(--gold)}p,li{line-height:1.55}.actions,.search-actions{display:flex;gap:8px;flex-wrap:wrap}.button{display:inline-flex;align-items:center;justify-content:center;min-height:42px;padding:0 15px;border:1px solid var(--line);border-radius:7px;background:#0b1522;color:var(--text);font-weight:700;text-decoration:none;cursor:pointer}.primary{background:var(--cyan);border-color:var(--cyan);color:#061313}.card{margin-top:14px;padding:20px;border:1px solid var(--line);border-radius:8px;background:rgba(10,19,31,.95)}.shopping-summary{display:grid;grid-template-columns:1fr auto;gap:18px;align-items:center;padding:26px;border-color:#3b6f7d;background:linear-gradient(135deg,#0a1b28,#081019)}.shopping-summary h2{margin-top:5px;font-size:clamp(22px,3vw,30px)}.shopping-summary #reasonSummary p{margin:5px 0;color:#c7d3db}.compact-card{display:grid;grid-template-columns:150px 1fr;gap:18px;align-items:center}.compact-card h2{margin:0}.purpose-grid{display:flex;flex-wrap:wrap;gap:8px}.ingredient-grid,.box-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}.purpose{padding:9px 12px;border:1px solid #31556a;border-radius:5px;background:#09111c}.ingredient,.box-item{padding:16px;border:1px solid #31556a;border-radius:7px;background:#09111c}.ingredient ul{margin:10px 0 0;padding-left:18px}.ingredient li{margin:4px 0;color:#c7d3db}.check{color:var(--cyan);font-weight:800}.tag{display:inline-block;margin:3px 4px 3px 0;padding:5px 8px;border:1px solid #2d7181;border-radius:5px;color:var(--cyan);font-size:13px}.muted{color:var(--muted)}.section-heading{display:flex;justify-content:space-between;gap:18px;align-items:end;margin-bottom:14px}.section-heading h2{margin:5px 0 0}.warning{border-left:3px solid var(--gold);padding:14px 16px;background:#111018}.why-panel{display:none;grid-column:1/-1;margin-top:0;padding:14px;border-left:3px solid var(--cyan);background:#08131c}.why-panel.open{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}.why-panel p{margin:0}.search-card .ingredient{margin-top:10px}.search-card .ingredient:first-child{margin-top:0}.search-group summary{cursor:pointer;color:var(--gold);font-size:17px;font-weight:800;list-style-position:outside}.search-group[open] summary{margin-bottom:12px}.search-actions{margin-top:12px}.search-actions a:nth-child(2){border-color:var(--gold)}.health-box-card{grid-template-columns:210px 1fr}.selection-details summary{cursor:pointer;color:var(--gold);font-weight:800}.selection-details[open] summary{margin-bottom:12px}.empty{text-align:center}.admin-link{color:var(--muted);font-size:13px}@media(max-width:820px){.ingredient-grid,.box-grid{grid-template-columns:1fr}.why-panel.open{grid-template-columns:1fr}.compact-card,.health-box-card{grid-template-columns:1fr}.section-heading{align-items:start;flex-direction:column}}@media(max-width:620px){.page{padding:12px}header{align-items:stretch;flex-direction:column}.actions,.actions>*{width:100%}.shopping-summary{grid-template-columns:1fr}.shopping-summary .button{width:100%}.search-actions{display:grid}.search-actions .button{width:100%}}
  </style>
  <link rel="stylesheet" href="site-navigation.css">
</head>
<body>
<main class="page">
  <header><div><div class="brand">IRIS MAPPING LAB</div><h1>쇼핑하기</h1></div><nav class="actions"><a class="button" href="final-report.html">총결과</a><a class="button" href="subscription.html">구독하기</a><a class="button" href="index.html">메인 화면</a></nav></header>
  <section class="card"><div class="section-heading"><div><span class="section-kicker">INGREDIENTS</span><h2>우선 비교 성분</h2></div><span class="muted">성분별 핵심 확인사항을 먼저 비교하세요.</span></div><div id="ingredientReasons" class="ingredient-grid"></div></section>
  <section class="card search-card"><h2>성분별 쇼핑 비교</h2><div id="searchGroups"></div></section>
  <section id="productSection" class="card"><h2>추천 제품</h2><div id="recommendedProducts" class="ingredient-grid"></div></section>
  <section class="card compact-card health-box-card"><div><h2>맞춤 건강박스</h2><p id="healthType"></p></div><div id="healthBox" class="box-grid"></div></section>
  <details class="card selection-details"><summary>제품 선별 기준 보기</summary><ol id="conditions"></ol><p class="muted">실시간 상품 정보는 공식 API 또는 관리자 제품DB 자료가 있을 때 적용됩니다.</p></details>
  <p id="warning" class="warning"></p>
  <p><a class="admin-link" href="product-admin.html">관리자 제품 설정</a></p>
</main>
<script src="care-engine.js"></script><script src="shopping-recommendation-db.js"></script>
<script>
  const analysis=IrisCareEngine.analyze(); const db=shoppingRecommendationDB;
  const adminSettings=readLocal("irisAdminShoppingSettings")||{}; const adminProducts=readLocal("irisAdminProducts")||[];
  const ingredientHelp={
    "마그네슘":["긴장 관리","수면 습관 관리","근육 기능 유지"],"비타민B군":["에너지 생성","피로 관리","영양 대사"],
    "밀크씨슬":["간 건강 기능성 원료 비교","실리마린 함량 확인","음주·복용 성분 점검"],"오메가3":["혈행 건강","중성지질 관리","성분 중복 확인"],
    "코엔자임Q10":["항산화 관리","혈압 관리 참고","복용약 상호작용 확인"],"프로바이오틱스":["장내 균형","배변 리듬","균주·보장균수 비교"],
    "프리바이오틱스":["유익균 먹이","장 건강 관리","당류 함량 확인"],"식이섬유":["배변 리듬","포만감 관리","수분 섭취 병행"],
    "여성 유산균":["여성 유익균 균형","질·장 건강 관리","균주명 확인"],"크랜베리":["비뇨 건강 관리","당류 확인","약 복용 주의"],
    "비타민C":["항산화 관리","철 흡수 보조","섭취량 확인"],"비타민D":["뼈 건강","면역 기능 유지","혈중 수치 확인"],"아연":["정상 면역 기능","세포 분열","장기 고용량 주의"],
    "L-테아닌":["긴장 완화 도움","카페인 섭취 점검","수면 습관 병행"]
  };
  const unique=(items)=>[...new Set(items.filter(Boolean))]; const esc=(v)=>String(v??"").replace(/[&<>"']/g,(c)=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
  function readLocal(key){try{return JSON.parse(localStorage.getItem(key)||"null")}catch(_){return null}}
  const primary=analysis.primary; const ingredients=unique(primary.flatMap((item)=>item.ingredients)).slice(0,6);
  document.querySelector("#ingredientReasons").innerHTML=ingredients.map((item)=>`<div class="ingredient"><h3>${esc(item)}</h3><ul>${(ingredientHelp[item]||["성분표 확인","일일 섭취량 확인"]).slice(0,2).map((text)=>`<li>${esc(text)}</li>`).join("")}</ul></div>`).join("")||'<p class="empty">비교할 추천 성분이 없습니다.</p>';
  function groupForIngredient(name){return db.productGroupDB.find((group)=>group.title===name||group.title.includes(name)||name.includes(group.title))}
  document.querySelector("#searchGroups").innerHTML=ingredients.map((ingredient)=>{const group=groupForIngredient(ingredient);const terms=group?(adminSettings[group.id]?.keywords||db.searchKeywordDB[group.id]||[]):[`${ingredient} 건강기능식품`,`${ingredient} 함량 표시`];const query=terms[0]||ingredient;return `<details class="ingredient search-group"><summary>${esc(ingredient)} 비교하기</summary><div>${terms.slice(0,3).map((term)=>`<span class="tag">${esc(term)}</span>`).join("")}</div><div class="search-actions"><a class="button primary" target="_blank" rel="noopener" href="https://search.shopping.naver.com/search/all?query=${encodeURIComponent(query)}">네이버</a><a class="button" target="_blank" rel="noopener" href="https://search.naver.com/search.naver?query=${encodeURIComponent(query+" 공식몰")}">공식몰</a><a class="button" target="_blank" rel="noopener" href="https://www.coupang.com/np/search?q=${encodeURIComponent(query)}">쿠팡</a></div></details>`}).join("");
  const selectedGroupIds=ingredients.map(groupForIngredient).filter(Boolean).map((group)=>group.id);const actualProducts=adminProducts.filter((product)=>selectedGroupIds.includes(product.category)&&Number(product.stock)>0).slice(0,5);
  document.querySelector("#recommendedProducts").innerHTML=actualProducts.map((product)=>`<article class="ingredient"><h3>${esc(product.name)}</h3><p><strong>${esc(product.brand)}</strong> · ${esc(product.ingredient)}</p><p class="muted">${Number(product.salePrice||0).toLocaleString("ko-KR")}원</p></article>`).join("");
  document.querySelector("#productSection").hidden=!actualProducts.length;
  document.querySelector("#healthType").innerHTML=`회원 건강유형: <strong>${esc(analysis.type)}</strong>`;
  const box=unique(primary.flatMap((item)=>item.box)).slice(0,6);document.querySelector("#healthBox").innerHTML=box.map((item)=>`<div class="box-item">${esc(item)}</div>`).join("");
  document.querySelector("#conditions").innerHTML=db.selectionConditionDB.map((item)=>`<li>${esc(item)}</li>`).join("");
  const caution=/(임신|수유|복용|간질환|간수치|신장질환|고혈압|심장질환|항응고)/.test(analysis.findings.map((item)=>`${item.label} ${item.value}`).join(" "));
  document.querySelector("#warning").innerHTML=caution?"<strong>구매 전 전문가 확인:</strong> 임신·약 복용·질환 관련 응답이 있어 의사 또는 약사 확인이 우선입니다.":"본 추천은 건강관리 제품 선택을 돕기 위한 참고 정보이며 진단이나 치료를 대신하지 않습니다.";
</script>
  <script src="site-navigation.js"></script>
</body></html>
