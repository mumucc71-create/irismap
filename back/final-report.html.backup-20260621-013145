<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>최종 종합 판독 | IRIS MAPPING LAB</title>
  <style>
    :root { color-scheme: dark; --bg:#05090f; --panel:#0b1320; --line:#234458; --text:#f4f7fa; --muted:#9eb0bd; --cyan:#36d8d0; --gold:#e8b74c; }
    * { box-sizing: border-box; }
    body { margin:0; min-height:100vh; color:var(--text); background:linear-gradient(180deg,#06111a 0,#03060a 100%); font-family:Arial,"Noto Sans KR",sans-serif; }
    .page { width:min(1180px,100%); margin:auto; padding:22px; }
    header { display:flex; align-items:center; justify-content:space-between; gap:18px; padding:18px 0 22px; border-bottom:1px solid var(--line); }
    .brand { color:var(--cyan); font-size:13px; font-weight:800; letter-spacing:.08em; }
    h1 { margin:7px 0 0; font-size:clamp(27px,4vw,42px); letter-spacing:0; }
    h2 { margin:0 0 16px; font-size:21px; }
    h3 { margin:0 0 8px; font-size:17px; color:var(--gold); }
    p { line-height:1.65; }
    .actions { display:flex; gap:9px; flex-wrap:wrap; }
    .button { min-height:42px; display:inline-flex; align-items:center; justify-content:center; padding:0 16px; border:1px solid var(--line); border-radius:7px; color:var(--text); background:#0b1522; font-weight:700; text-decoration:none; cursor:pointer; }
    .button.primary { color:#031312; background:var(--cyan); border-color:var(--cyan); }
    .status-grid,.source-grid,.detail-grid { display:grid; gap:12px; }
    .status-grid { grid-template-columns:repeat(3,minmax(0,1fr)); margin:20px 0; }
    .source-grid { grid-template-columns:repeat(3,minmax(0,1fr)); }
    .detail-grid { grid-template-columns:repeat(2,minmax(0,1fr)); margin-top:12px; }
    .detail-grid .wide { grid-column:1 / -1; }
    .card { min-width:0; padding:20px; border:1px solid var(--line); border-radius:8px; background:rgba(10,19,31,.92); }
    .status { display:flex; justify-content:space-between; gap:10px; align-items:center; }
    .status b { color:var(--gold); }
    .status .ready { color:var(--cyan); }
    .summary { margin:0 0 14px; padding:24px; border-color:#3b6e82; }
    .rank { padding:12px 0; border-top:1px solid rgba(80,119,139,.45); }
    .rank:first-of-type { border-top:0; padding-top:0; }
    .rank strong { display:block; margin-bottom:4px; }
    .meta,.empty,.notice { color:var(--muted); }
    ul { margin:8px 0 0; padding-left:20px; line-height:1.65; }
    .notice { margin-top:16px; padding:16px 18px; border-left:3px solid var(--gold); background:#0a1018; font-size:14px; }
    .missing-link { color:var(--cyan); }
    .response-list li { margin-bottom:7px; }
    .match-box { padding:14px 0; border-top:1px solid rgba(80,119,139,.45); }
    .match-box:first-child { border-top:0; padding-top:0; }
    @media (max-width:850px) { .source-grid,.detail-grid { grid-template-columns:1fr; }.detail-grid .wide{grid-column:auto} }
    @media (max-width:650px) { .page{padding:12px} header{align-items:stretch;flex-direction:column}.actions,.actions>*{width:100%}.status-grid{grid-template-columns:1fr} }
    @media print { body{background:#fff;color:#111}.actions{display:none}.card{background:#fff;border-color:#aaa}.meta,.empty,.notice{color:#444} }
  </style>
</head>
<body>
  <main class="page">
    <header>
      <div><div class="brand">IRIS MAPPING LAB</div><h1>최종 종합 판독</h1></div>
      <nav class="actions">
        <a class="button" href="reading.html">홍채 판독 결과</a>
        <a class="button" href="index.html">메인 화면</a>
        <button class="button primary" type="button" onclick="window.print()">저장/인쇄</button>
      </nav>
    </header>

    <section id="sourceStatus" class="status-grid" aria-label="자료 준비 상태"></section>
    <section class="card summary"><h2>세 자료 종합 참고</h2><div id="combinedSummary"></div></section>
    <section class="source-grid">
      <article class="card"><h2>홍채 관찰 요약</h2><div id="irisSummary"></div></article>
      <article class="card"><h2>라이프케어진단</h2><div id="healthSummary"></div></article>
      <article class="card"><h2>AI 보험상담 요약</h2><div id="insuranceSummary"></div></article>
    </section>
    <section class="detail-grid">
      <article class="card"><h2>12시 뇌·신경 영역 상세</h2><div id="brainTwelveSummary"></div></article>
      <article class="card"><h2>라이프케어진단 상세 응답</h2><div id="healthDetails"></div></article>
      <article class="card wide"><h2>핵심 영역 상세 · 간·심장·뇌</h2><div id="coreAreaSummary"></div></article>
      <article class="card wide"><h2>홍채·병력·현재 증상 최종 종합 해석</h2><div id="crossComparison"></div></article>
    </section>
    <p class="notice">본 화면은 상담 순서를 정리하는 참고자료입니다. 홍채 관찰은 의학적으로 확립된 진단 검사가 아니며, 건강문진은 의료진의 진단과 치료를 대체하지 않습니다. 보험상담 결과 역시 가입 가능 여부나 특정 상품의 적합성을 확정하지 않습니다.</p>
  </main>
  <script>
    const sessionPhone = normalizePhone(localStorage.getItem("irisMappingSession"));
    const iris = readJson("irisReadingResult");
    const health = sessionPhone ? readJson(`irisHealthTest:${sessionPhone}`) : null;
    const insurance = sessionPhone ? readJson(`irisAiInsuranceConsult_${sessionPhone}`) : null;
    const irisForAccount = iris && (!iris.accountPhone || normalizePhone(iris.accountPhone) === sessionPhone) ? iris : null;

    function normalizePhone(value) { let digits=String(value||"").replace(/\D/g,""); if(digits.length===10&&digits.startsWith("10")) digits=`0${digits}`; return digits; }
    function readJson(key) { try { return JSON.parse(localStorage.getItem(key)||"null"); } catch (_) { return null; } }
    function escapeHtml(value) { return String(value??"").replace(/[&<>"']/g,(char)=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[char])); }
    function list(value) { return Array.isArray(value) ? value.filter(Boolean).join(", ") : (value || "미기록"); }
    function isMeaningful(value) {
      if (Array.isArray(value)) return value.some(isMeaningful);
      const text=String(value??"").trim();
      if (!text) return false;
      return !["아니오","전혀 아니다","없음","해당 없음","정상","모름","잘 모름","미기록","특별히 없음","통증 없음","환경노출 없음","알레르기 없음"].includes(text);
    }

    const irisTop = buildIrisSummary(irisForAccount);
    const healthResult = buildHealthSummary(health);
    const healthTop = healthResult.groups;
    const healthFindings = healthResult.findings;
    const insuranceTop = buildInsuranceSummary(insurance);
    buildBrainTwelveSummary(irisForAccount);
    const coreAreaResults = buildCoreAreaSummary(irisForAccount, healthFindings);
    buildCrossComparison(irisForAccount, healthFindings);
    renderStatus();
    renderCombined();

    function buildIrisSummary(data) {
      const target=document.querySelector("#irisSummary");
      if (!data) { target.innerHTML='<p class="empty">현재 계정의 홍채 판독 결과가 없습니다.</p><a class="missing-link" href="index.html">홍채 판독하러 가기</a>'; return []; }
      const grouped={};
      [["우안",data.right||[]],["좌안",data.left||[]]].forEach(([eye,items])=>items.forEach((item)=>{
        const key=item.area||item.code||"미분류";
        grouped[key] ||= {area:key,score:0,eyes:new Set(),consultation:item.consultation||item.dbConsultation||"상담 시 참고합니다."};
        grouped[key].score += Number(item.priorityScore||item.score||0); grouped[key].eyes.add(eye);
      }));
      const top=Object.values(grouped).map((item)=>({...item,score:item.score+(item.eyes.size>1?5:0)})).sort((a,b)=>b.score-a.score).slice(0,3);
      const collarette=data.collarette||{};
      const collaretteText=[collarette.right?.consultation,collarette.left?.consultation].filter(Boolean).join(" / ") || "꽃모양 영역 기록 없음";
      target.innerHTML = top.map((item,index)=>`<div class="rank"><h3>${index+1}순위 · ${escapeHtml(item.area)}</h3><strong>${[...item.eyes].join("·")}</strong><span class="meta">${escapeHtml(item.consultation)}</span></div>`).join("") + `<p class="meta"><strong>좌우 꽃모양 영역 종합:</strong> ${escapeHtml(collaretteText)}</p>`;
      return top;
    }

    function buildHealthSummary(data) {
      const target=document.querySelector("#healthSummary");
      const detailTarget=document.querySelector("#healthDetails");
      if (!data) { target.innerHTML='<p class="empty">저장된 라이프케어진단이 없습니다.</p><a class="missing-link" href="health.html">라이프케어진단 작성하기</a>'; detailTarget.innerHTML='<p class="empty">자료 없음</p>'; return {groups:[],findings:[]}; }
      const names={familyHistory:"가족력·과거력",lifestyle:"생활리듬·수면",diet:"식습관·섭취",stress:"스트레스 원인",personality:"성격·감정 반응",occupation:"직업환경",riskEnvironment:"사고·환경 노출",symptoms:"현재 증상",healthAwareness:"건강 관심도",foodSafetyAwareness:"식품 안전 인식",environmentalExposureAwareness:"환경 노출 인식",cookingStorageHabits:"조리·보관 습관",supplementUse:"건강식품 섭취",dentalOralHealth:"치아·구강 건강",allergySkinEnt:"알레르기·피부·이비인후과",mentalHealth:"정신건강·정서",maleHealth:"남성 건강",femaleHealth:"여성 건강",inflammationPattern:"반복 염증",pediatricHealth:"어린이 성장·건강",preschoolDevelopment:"유아 발달",lowerElementary:"초등 저학년",upperElementary:"초등 고학년"};
      const meta=new Set(["phone","status","updatedAt","createdAt","answerLabels"]); const labels=data.answerLabels||{};
      const groups=Object.entries(data).filter(([key,value])=>!meta.has(key)&&value&&typeof value==="object"&&!Array.isArray(value)).map(([key,answers])=>{
        const findings=Object.entries(answers).filter(([name,value])=>isConcernFinding(name,value)).map(([name,value])=>({name,label:labels[name]||fallbackHealthLabel(name),value,group:key,groupTitle:names[key]||"기타 건강 영역"}));
        return {key,title:names[key]||"기타 건강 영역",count:findings.length,findings};
      }).filter((group)=>group.count).sort((a,b)=>b.count-a.count);
      const findings=groups.flatMap((group)=>group.findings);
      const top=groups.slice(0,6);
      target.innerHTML = top.length ? `<p class="meta">주의·불편 응답 ${findings.length}개를 분야별로 정리했습니다.</p>`+top.map((group,index)=>`<div class="rank"><h3>${index+1}순위 · ${escapeHtml(group.title)}</h3><span class="meta">확인 항목 ${group.count}개</span></div>`).join("") : '<p class="empty">현재 저장 답변에서 뚜렷한 주의 응답이 확인되지 않습니다.</p>';
      detailTarget.innerHTML=findings.length?`<ul class="response-list">${findings.slice(0,30).map((item)=>`<li><strong>${escapeHtml(item.groupTitle)}</strong> · ${escapeHtml(item.label)} <span class="meta">(${escapeHtml(list(item.value))})</span></li>`).join("")}</ul>${findings.length>30?`<p class="meta">그 외 ${findings.length-30}개 응답은 분야별 집계에 포함되었습니다.</p>`:""}`:'<p class="empty">표시할 주의 응답이 없습니다.</p>';
      return {groups:top,findings};
    }

    function fallbackHealthLabel(name) {
      const labels={fatigue:"쉽게 피로해진다",jaundice:"피부나 눈 흰자가 노랗게 보인다",headache:"두통이나 편두통이 있다",dizziness:"어지럽거나 균형을 잃는다",memory:"기억력이나 집중력이 떨어졌다",sleepDifficulty:"잠들기 어렵다",wakeAtDawn:"새벽에 자주 깬다",tiredAfterSleep:"자고 일어나도 피곤하다",chestPain:"가슴 통증이 있다",palpitations:"가슴 두근거림이나 불규칙한 맥박이 있다",coldHandsFeet:"손발이 차다",legSwelling:"다리나 발이 붓는다",heartUltrasound:"심장 초음파 검사에서 이상을 들은 적이 있다",heartProcedure:"심장 관련 수술이나 시술 경험이 있다",cough:"기침이 자주 난다",phlegm:"가래가 자주 생긴다",shortnessBreath:"숨이 차거나 호흡이 어렵다",indigestion:"소화가 잘 안 된다",reflux:"속쓰림이나 위산 역류가 있다",constipation:"변비가 있다",diarrhea:"설사가 잦다",nocturia:"밤에 화장실을 자주 간다",darkFoamyUrine:"소변이 진하거나 거품이 오래 남는다"};
      return labels[name]||"세부 문항";
    }

    function isConcernFinding(name,value) {
      const values=Array.isArray(value)?value:[value];
      const protective=new Set(["healthInterest","healthSearch","healthCheckupHabit","healthExpenseWilling","checkOrigin","checkLabel","checkAdditives","checkSugarSodium","organicFood","glassSteelUse","brushingBeforeSleep","flossInterdental","regularDentalCheckup"]);
      const profileFields=new Set(["name","phone","gender","age","height","weight","bloodType","maritalStatus","childCount","guardianName","guardianRelation","studentGrade"]);
      if(profileFields.has(name)) return false;
      return values.some((raw)=>{
        const text=String(raw??"").trim();
        if(protective.has(name)) return text==="아니오"||text==="전혀 아니다";
        if(!isMeaningful(text)) return false;
        if(name==="brushingCount") return text==="하루 1회 이하";
        if(name==="brushingDuration") return text==="1분 미만";
        if(["예","현재 있음","과거 있음","병원 진단 있음","수술/시술 있음","재발 있음","현재 불편감","악화 습관","후유증","가끔","자주","거의 매일","가벼움","중간","심함","조금 걱정됨","많이 걱정됨","매우 걱정됨"].includes(text)) return true;
        return !["하루 2회","하루 3회 이상","1~2분","2~3분","3분 이상"].includes(text);
      });
    }

    function allIrisObservations(data) {
      if(!data) return [];
      const source=data.allObservations||{right:data.right||[],left:data.left||[]};
      return [["우안",source.right||[]],["좌안",source.left||[]]].flatMap(([eye,items])=>items.map((item)=>({...item,eyeLabel:eye})));
    }

    function buildBrainTwelveSummary(data) {
      const target=document.querySelector("#brainTwelveSummary");
      if(!data){target.innerHTML='<p class="empty">홍채 판독 자료가 없습니다.</p>';return;}
      const items=allIrisObservations(data).filter((item)=>String(item.code||"").startsWith("12-")).sort((a,b)=>(b.priorityScore||0)-(a.priorityScore||0));
      const areas={"12-1":"대뇌피질","12-2":"소뇌","12-3":"변연계","12-4":"뇌간","12-5":"시상하부","12-6":"눈·귀 신경"};
      target.innerHTML=items.length?items.map((item)=>`<div class="rank"><h3>${escapeHtml(item.eyeLabel)} · ${escapeHtml(item.code)} ${escapeHtml(item.area||areas[item.code]||"")}</h3><strong>${escapeHtml((item.patterns||[]).map((pattern)=>pattern.type).join(", ")||item.type||"관찰 신호")}</strong><span class="meta">관찰 강도 ${escapeHtml(item.score||0)} · ${escapeHtml(item.consultation||item.dbConsultation||"상담 시 참고합니다.")}</span></div>`).join(""):'<p class="empty">이번 사진에서 기준을 넘은 12시 관찰 신호는 없습니다. 신호가 없다는 것이 질환 유무를 뜻하지는 않습니다.</p>';
    }

    function comparisonThemes() {
      return [
        {hours:[11,12,1],title:"뇌·신경·정서",keywords:["뇌","신경","두통","어지","기억","집중","수면","불안","우울","스트레스","감정"],fieldNames:["sleepDifficulty","wakeAtDawn","tiredAfterSleep","daytimeSleepiness","fatigue","headache","dizziness","fainting","numbness","weakness","tremor","memory","seizure","depressedMood","panicFeeling","attentionDifficulty","futureAnxiety"]},
        {hours:[2,3],title:"폐·기관지·호흡",keywords:["폐","기관지","호흡","기침","가래","천식","비염","흉부"],fieldNames:["cough","phlegm","shortnessBreath","wheezing","chestTightness","recurrentRespiratory","rhinitis","allergicRhinitis","sinusitis"]},
        {hours:[4],title:"위·췌장·소화",keywords:["위","췌장","소화","복부","위산","속쓰림","구토"],fieldNames:["indigestion","bloating","nausea","reflux","abdominalPain"]},
        {hours:[5,6],title:"신장·비뇨·골반",keywords:["신장","요관","소변","비뇨","방광","골반","생식","전립선","여성"],fieldNames:["frequentUrine","nocturia","painfulUrine","incompleteUrine","urineLeak","bloodUrine","darkFoamyUrine","flankPain","weakUrineFlow","prostateDiscomfort"]},
        {hours:[7],title:"간·담낭",keywords:["간","담낭","간수치","황달","음주","숙취"],fieldNames:["jaundice","fatigue","alcoholUse","drinkingFrequency","hangover","liverDisease"]},
        {hours:[8],title:"장·비장·면역",keywords:["소장","대장","장","변비","설사","비장","면역"],fieldNames:["constipation","diarrhea","stoolChange","bloodStool","recurrentInflammationArea"]},
        {hours:[9],title:"심장·순환·흉부",keywords:["심장","순환","혈압","가슴","두근","혈관","판막"],fieldNames:["chestPain","palpitations","coldHandsFeet","standingDizziness","legSwelling","legVeins","easyBruising","heartUltrasound","heartProcedure","heartValve"]},
        {hours:[10],title:"목·어깨·림프·갑상선",keywords:["목","어깨","림프","갑상선","편도"],fieldNames:["soreThroat","neckSwelling","tonsillitis","neckBackPain"]}
      ];
    }

    function healthMatchesTheme(item,theme) {
      if(theme.fieldNames.includes(item.name)) return true;
      const text=`${item.label} ${list(item.value)}`;
      return theme.keywords.some((word)=>text.includes(word));
    }

    function isHistoricalFinding(item) {
      const text=`${item.name} ${item.label} ${list(item.value)}`;
      return item.group==="familyHistory"||/History|Diagnosis|Surgery|Procedure|past/i.test(item.name)||/(과거|진단|수술|시술|재발|가족력)/.test(text);
    }

    function isCurrentFinding(item) {
      const text=list(item.value);
      return !isHistoricalFinding(item)||/(현재|가끔|자주|매일|중간|심함|불편)/.test(text);
    }

    function renderFindingEvidence(items,emptyText) {
      return items.length
        ? escapeHtml(items.slice(0,8).map((item)=>`${item.label}(${list(item.value)})`).join(", "))
        : emptyText;
    }

    function buildCoreAreaSummary(data,findings) {
      const target=document.querySelector("#coreAreaSummary");
      if(!data){target.innerHTML='<p class="empty">홍채 판독 자료가 없습니다.</p>';return [];}
      const irisItems=allIrisObservations(data);
      const coreThemes=comparisonThemes().filter((theme)=>["간·담낭","심장·순환·흉부","뇌·신경·정서"].includes(theme.title));
      const results=coreThemes.map((theme)=>({
        ...theme,
        eyeItems:irisItems.filter((item)=>theme.hours.includes(Number(String(item.code||"").split("-")[0]))),
        healthItems:findings.filter((item)=>healthMatchesTheme(item,theme))
      }));
      const legacyNotice=!data.allObservations?'<p class="notice">이 결과는 이전 방식으로 저장되어 좌우 상위 3개 관찰값만 포함합니다. 간·심장·뇌 전체 영역을 확인하려면 메인 화면에서 판독하기를 한 번 다시 실행해 주세요.</p>':'';
      target.innerHTML=legacyNotice+results.map((result)=>`<div class="match-box"><h3>${escapeHtml(result.title)}</h3><p><strong>홍채지도에서 확인된 항목:</strong> ${result.eyeItems.length?escapeHtml(result.eyeItems.map((item)=>`${item.eyeLabel} ${item.code} ${item.area}(${item.score})`).join(", ")):'기준을 넘은 저장 관찰값 없음'}</p><p><strong>라이프케어진단 관련 응답:</strong> ${result.healthItems.length?escapeHtml(result.healthItems.slice(0,10).map((item)=>`${item.label}(${list(item.value)})`).join(", ")):'관련 주의 응답 없음'}</p><p class="meta">한쪽에 기록이 없더라도 질환이 없다는 뜻은 아니며, 양쪽에 함께 기록되어도 질환을 확정하지 않습니다.</p></div>`).join("");
      return results;
    }

    function buildCrossComparison(data,findings) {
      const target=document.querySelector("#crossComparison");
      if(!data||!findings.length){target.innerHTML='<p class="empty">홍채 판독과 라이프케어진단 자료가 모두 있어야 교차 참고가 가능합니다.</p>';return;}
      const themes=comparisonThemes();
      const irisItems=allIrisObservations(data);
      const matches=themes.map((theme)=>{
        const eyeItems=irisItems.filter((item)=>theme.hours.includes(Number(String(item.code||"").split("-")[0])));
        const healthItems=findings.filter((item)=>healthMatchesTheme(item,theme));
        return {...theme,eyeItems,healthItems};
      }).filter((theme)=>theme.eyeItems.length&&theme.healthItems.length).sort((a,b)=>(b.eyeItems.length+b.healthItems.length)-(a.eyeItems.length+a.healthItems.length));
      target.innerHTML=matches.length
        ? `<p><strong>최종 우선 확인 부위:</strong> ${escapeHtml(matches.slice(0,3).map((match)=>match.title).join(", "))}</p>`+matches.slice(0,6).map((match)=>{
            const historyItems=match.healthItems.filter(isHistoricalFinding);
            const currentItems=match.healthItems.filter(isCurrentFinding);
            return `<div class="match-box">
              <h3>${escapeHtml(match.title)}</h3>
              <p><strong>① 과거 병력·가족력 근거:</strong> ${renderFindingEvidence(historyItems,"관련 기록 없음")}</p>
              <p><strong>② 현재 증상·생활습관 근거:</strong> ${renderFindingEvidence(currentItems,"관련 기록 없음")}</p>
              <p><strong>③ 홍채지도 관찰 근거:</strong> ${escapeHtml(match.eyeItems.slice(0,8).map((item)=>`${item.eyeLabel} ${item.code} ${item.area} · ${item.type||"관찰 신호"} ${item.score||0}`).join(", "))}</p>
              <p><strong>종합 판단:</strong> 과거 기록과 현재 불편 중 확인된 내용이 전통 홍채지도의 ${escapeHtml(match.title)} 관련 관찰 영역과 같은 상담 주제로 겹칩니다. 따라서 이 부위는 현재 생활관리와 전문 검사·상담에서 우선 확인할 영역으로 정리합니다.</p>
              <p class="meta">이는 해당 장기가 약하다는 판정이나 증상의 원인을 확정한 결과가 아닙니다.</p>
            </div>`;
          }).join("")
        : '<p class="empty">병력·현재 증상과 홍채 관찰이 같은 상담 주제로 함께 기록된 영역이 없습니다. 이것은 정상·질환 여부를 뜻하지 않습니다.</p>';
    }

    function buildInsuranceSummary(data) {
      const target=document.querySelector("#insuranceSummary");
      if (!data) { target.innerHTML='<p class="empty">저장된 AI 보험상담이 없습니다.</p><a class="missing-link" href="ai-health.html">보험상담 작성하기</a>'; return []; }
      const answers=data.answers||{}; const recs=Array.isArray(data.recommendation)?data.recommendation:[];
      target.innerHTML=`<p><strong>걱정 대상:</strong> ${escapeHtml(list(answers.worryTarget))}<br><strong>주요 걱정:</strong> ${escapeHtml(list(answers.personalRiskConcern))}<br><strong>현재 보험:</strong> ${escapeHtml(list(answers.currentInsurance))}<br><strong>예산:</strong> ${escapeHtml(list(answers.budget))}</p>` + (recs.length?recs.slice(0,5).map((item,index)=>`<div class="rank"><h3>${index+1}순위 · ${escapeHtml(item.title)}</h3><span class="meta">${escapeHtml(item.reason)}</span></div>`).join(""):'<p class="empty">상담 우선순위가 아직 생성되지 않았습니다.</p>');
      return recs;
    }

    function renderStatus() {
      const items=[["홍채 판독",!!irisForAccount],["라이프케어진단",!!health],["AI 보험상담",!!insurance]];
      document.querySelector("#sourceStatus").innerHTML=items.map(([name,ready])=>`<div class="card status"><strong>${name}</strong><b class="${ready?"ready":""}">${ready?"준비 완료":"자료 없음"}</b></div>`).join("");
    }

    function renderCombined() {
      const parts=[];
      if (irisTop.length) parts.push(`홍채 관찰에서는 <strong>${escapeHtml(irisTop.map((item)=>item.area).join(", "))}</strong> 영역이 우선 확인됩니다.`);
      if (healthTop.length) parts.push(`라이프케어진단에서는 <strong>${escapeHtml(healthTop.map((item)=>item.title).join(", "))}</strong> 관련 주의·불편 응답이 상대적으로 많이 확인됩니다.`);
      if (insuranceTop.length) parts.push(`보험상담에서는 <strong>${escapeHtml(insuranceTop.slice(0,3).map((item)=>item.title).join(", "))}</strong> 순서로 점검 방향이 정리됩니다.`);
      const confirmedCore=coreAreaResults.filter((item)=>item.eyeItems.length&&item.healthItems.length);
      if(confirmedCore.length) parts.push(`홍채지도 관찰과 라이프케어진단에서 함께 확인된 핵심 상담 주제는 <strong>${escapeHtml(confirmedCore.map((item)=>item.title).join(", "))}</strong>입니다.`);
      if (!sessionPhone) parts.push('로그인 계정을 확인할 수 없어 계정별 문진과 보험상담을 불러오지 못했습니다.');
      if (!parts.length) parts.push('종합할 저장 자료가 없습니다. 세 항목을 먼저 진행해 주세요.');
      parts.push('홍채와 라이프케어에서 같은 주제가 함께 보여도 질환의 존재나 미래 발병을 예측한 것으로 해석하지 않습니다. 생활관리와 전문 상담에서 무엇을 먼저 확인할지 정하는 참고자료로만 사용합니다.');
      document.querySelector("#combinedSummary").innerHTML=parts.map((text)=>`<p>${text}</p>`).join("");
    }
  </script>
</body>
</html>
