const adminDb=window.shoppingRecommendationDB;
const groupSelect=document.querySelector("#groupId");
const productCategory=document.querySelector('[name="category"]');
const groupSettings=readAdmin("irisAdminShoppingSettings")||{};
let adminProducts=readAdmin("irisAdminProducts")||[];
const options=adminDb.productGroupDB.map((group)=>'<option value="'+escapeAdmin(group.id)+'">'+escapeAdmin(group.title)+'</option>').join("");
groupSelect.innerHTML=options;productCategory.innerHTML=options;
syncGroupKeywords();renderProducts();

function readAdmin(key){try{return JSON.parse(localStorage.getItem(key)||"null")}catch(_){return null}}
function escapeAdmin(value){return String(value??"").replace(/[&<>"']/g,(c)=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]))}
function syncGroupKeywords(){const id=groupSelect.value;document.querySelector("#groupKeywords").value=(groupSettings[id]?.keywords||adminDb.searchKeywordDB[id]||[]).join("\n")}
groupSelect.addEventListener("change",syncGroupKeywords);
document.querySelector("#groupForm").addEventListener("submit",(event)=>{event.preventDefault();const id=groupSelect.value;groupSettings[id]={keywords:document.querySelector("#groupKeywords").value.split(/\r?\n/).map((item)=>item.trim()).filter(Boolean),updatedAt:new Date().toISOString()};localStorage.setItem("irisAdminShoppingSettings",JSON.stringify(groupSettings));document.querySelector("#status").textContent="제품군 검색어를 저장했습니다.";});
document.querySelector("#productForm").addEventListener("submit",(event)=>{event.preventDefault();const data=Object.fromEntries(new FormData(event.currentTarget).entries());data.id="P"+Date.now();data.createdAt=new Date().toISOString();data.wholesalePrice=Number(data.wholesalePrice)||0;data.salePrice=Number(data.salePrice)||0;data.stock=Number(data.stock)||0;adminProducts.push(data);localStorage.setItem("irisAdminProducts",JSON.stringify(adminProducts));event.currentTarget.reset();renderProducts();document.querySelector("#status").textContent="제품을 저장했습니다.";});
function renderProducts(){const titles=Object.fromEntries(adminDb.productGroupDB.map((group)=>[group.id,group.title]));document.querySelector("#productRows").innerHTML=adminProducts.length?adminProducts.map((product)=>'<tr><td>'+escapeAdmin(titles[product.category]||product.category)+'</td><td>'+escapeAdmin(product.name)+'</td><td>'+escapeAdmin(product.brand)+'</td><td>'+Number(product.salePrice||0).toLocaleString("ko-KR")+'원</td><td>'+escapeAdmin(product.stock)+'</td><td><button type="button" data-delete="'+escapeAdmin(product.id)+'">삭제</button></td></tr>').join(""):'<tr><td colspan="6" class="muted">등록된 실제 제품이 없습니다.</td></tr>';document.querySelectorAll("[data-delete]").forEach((button)=>button.addEventListener("click",()=>{adminProducts=adminProducts.filter((product)=>product.id!==button.dataset.delete);localStorage.setItem("irisAdminProducts",JSON.stringify(adminProducts));renderProducts();}));}
