:root {
  color-scheme: light;
  --bg: #f4f5ef;
  --ink: #151916;
  --muted: #656d67;
  --line: #d9ded7;
  --panel: #ffffff;
  --accent: #32d7ca;
  --accent-2: #b74f2a;
  --soft: #e8f2ee;
  --dark: #202520;
  --shadow: 0 18px 50px rgba(24, 34, 30, 0.12);
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  background: var(--bg);
  color: var(--ink);
  font-family: Inter, "Segoe UI", "Noto Sans KR", Arial, sans-serif;
}

button,
input {
  font: inherit;
}

[hidden] {
  display: none !important;
}

button,
.file-button {
  align-items: center;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 8px;
  color: var(--ink);
  cursor: pointer;
  display: inline-flex;
  font-weight: 800;
  justify-content: center;
  min-height: 40px;
  padding: 0 14px;
}

button:disabled {
  cursor: not-allowed;
  opacity: 0.46;
}

.auth-screen {
  align-items: center;
  background:
    radial-gradient(circle at 50% 34%, rgba(33, 108, 92, 0.16), transparent 34%),
    linear-gradient(180deg, #f7f8f3 0%, #e7ece5 100%);
  display: flex;
  min-height: 100vh;
  padding: 24px;
}

.auth-card {
  background: var(--panel);
  border: 1px solid var(--line);
  box-shadow: var(--shadow);
  display: grid;
  gap: 16px;
  margin: 0 auto;
  max-width: 520px;
  padding: 28px;
  width: 100%;
}

.auth-copy {
  color: var(--muted);
  line-height: 1.5;
  margin: 0;
}

.auth-form {
  display: grid;
  gap: 12px;
}

.auth-form label {
  color: var(--muted);
  display: grid;
  font-size: 13px;
  font-weight: 800;
  gap: 6px;
}

.auth-form input {
  border: 1px solid var(--line);
  border-radius: 8px;
  min-height: 42px;
  padding: 0 12px;
}

.auth-form input:focus {
  border-color: var(--accent);
  outline: 3px solid rgba(33, 108, 92, 0.14);
}

.auth-divider {
  align-items: center;
  color: var(--muted);
  display: grid;
  font-size: 12px;
  font-weight: 800;
  gap: 10px;
  grid-template-columns: 1fr auto 1fr;
}

.auth-divider::before,
.auth-divider::after {
  background: var(--line);
  content: "";
  height: 1px;
}

.auth-message {
  color: var(--accent-2);
  font-size: 13px;
  font-weight: 800;
  min-height: 18px;
  margin: 0;
}

.app-shell {
  display: grid;
  gap: 16px;
  grid-template-columns: 1fr;
  min-height: 100vh;
  padding: 16px 16px 92px;
}

.workspace,
.side-panel {
  background: var(--panel);
  border: 1px solid var(--line);
  box-shadow: var(--shadow);
}

.workspace {
  display: grid;
  grid-template-rows: auto minmax(0, 1fr);
  min-width: 0;
}

.topbar {
  align-items: center;
  border-bottom: 1px solid var(--line);
  display: flex;
  gap: 16px;
  justify-content: space-between;
  padding: 18px 20px;
}

.eyebrow {
  color: var(--accent);
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 0;
  margin: 0 0 4px;
  text-transform: uppercase;
}

.main-title {
  display: grid;
  gap: 8px;
}

.topbar .main-brand {
  justify-content: flex-start;
  margin-top: 0;
}

.topbar .main-brand .auth-logo {
  height: 34px;
  width: 34px;
}

h1,
h2 {
  letter-spacing: 0;
  margin: 0;
}

h1 {
  font-size: 28px;
  line-height: 1.15;
}

h2 {
  font-size: 16px;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: flex-end;
}

.file-button input {
  display: none;
}

.primary,
#exportButton,
#autoDetectButton {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
}

.canvas-wrap {
  align-items: flex-start;
  background: var(--dark);
  display: flex;
  justify-content: center;
  min-height: 360px;
  overflow: hidden;
  position: relative;
}

#irisCanvas {
  aspect-ratio: 32 / 9;
  display: block;
  height: auto;
  max-width: 100%;
  min-width: 0;
  width: 100%;
}

#irisCanvas.is-stacked {
  aspect-ratio: 8 / 9;
}

.empty-state {
  align-items: center;
  color: #f5f6f1;
  display: flex;
  flex-direction: column;
  gap: 8px;
  inset: 0;
  justify-content: center;
  padding: 24px;
  pointer-events: none;
  position: absolute;
  text-align: center;
}

.empty-state[hidden] {
  display: none;
}

.empty-state strong {
  font-size: 24px;
}

.empty-state span {
  color: rgba(245, 246, 241, 0.74);
  max-width: 540px;
}

.side-panel {
  display: grid;
  gap: 16px;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  overflow: visible;
  padding: 16px;
}

.panel-block {
  border-bottom: 1px solid var(--line);
  display: grid;
  gap: 14px;
  padding-bottom: 16px;
}

.reference-preview {
  align-items: center;
  aspect-ratio: 16 / 9;
  background: #111411;
  border: 1px solid var(--line);
  border-radius: 8px;
  color: rgba(255, 255, 255, 0.72);
  display: flex;
  justify-content: center;
  overflow: hidden;
}

.reference-preview img {
  display: none;
  height: 100%;
  object-fit: contain;
  width: 100%;
}

.photo-grid {
  display: grid;
  gap: 8px;
  grid-template-columns: 1fr 1fr;
}

.photo-card {
  align-items: flex-start;
  display: grid;
  gap: 4px;
  justify-content: stretch;
  min-height: 76px;
  padding: 10px;
  text-align: left;
}

.photo-card.active {
  border-color: var(--accent);
  box-shadow: inset 0 0 0 2px rgba(33, 108, 92, 0.18);
}

.photo-title {
  color: var(--accent);
  font-size: 16px;
}

.photo-name {
  color: var(--muted);
  font-size: 12px;
  overflow-wrap: anywhere;
}

.hint {
  color: var(--muted);
  font-size: 12px;
  line-height: 1.5;
  margin: 0;
}

.control {
  color: var(--muted);
  display: grid;
  gap: 8px;
  font-size: 13px;
  font-weight: 800;
}

.control input {
  accent-color: var(--accent);
  width: 100%;
}

.button-row {
  display: grid;
  gap: 8px;
  grid-template-columns: 1fr 1fr;
}

.panel-block:has(#centerX) {
  backdrop-filter: blur(14px);
  background: rgba(255, 255, 255, 0.94);
  border: 1px solid rgba(217, 222, 215, 0.9);
  border-radius: 10px;
  bottom: 18px;
  box-shadow: 0 14px 40px rgba(0, 0, 0, 0.22);
  display: grid;
  gap: 10px;
  grid-template-columns: auto repeat(4, minmax(112px, 1fr)) auto;
  left: 28px;
  max-width: none;
  padding: 10px;
  position: fixed;
  right: 28px;
  z-index: 20;
}

.panel-block:has(#centerX) h2 {
  align-self: center;
  white-space: nowrap;
}

.panel-block:has(#centerX) .control {
  gap: 4px;
  min-width: 0;
}

.panel-block:has(#centerX) .button-row {
  align-self: end;
  grid-template-columns: 1fr;
  min-width: 96px;
}

.panel-block:has(#centerX) button {
  min-height: 30px;
  padding: 0 10px;
}

.selection-details {
  color: var(--muted);
  display: grid;
  font-size: 14px;
  gap: 8px;
  line-height: 1.55;
}

.selection-details dl {
  display: grid;
  gap: 7px;
  grid-template-columns: 86px 1fr;
  margin: 0;
}

.selection-details dt {
  color: var(--muted);
  font-weight: 900;
}

.selection-details dd {
  margin: 0;
}

.marker-list,
.detail-map {
  display: grid;
  gap: 10px;
}

.marker-list.empty {
  color: var(--muted);
  font-size: 14px;
}

.marker-item {
  border: 1px solid var(--line);
  border-radius: 8px;
  display: grid;
  gap: 4px;
  padding: 10px;
}

.marker-item strong {
  color: var(--accent);
}

.marker-item span {
  color: var(--muted);
  font-size: 13px;
}

.zone-head {
  align-items: center;
  border: 1px solid var(--line);
  border-left-width: 6px;
  border-radius: 8px;
  display: grid;
  gap: 10px;
  grid-template-columns: auto 1fr;
  padding: 10px;
}

.zone-head p {
  color: var(--muted);
  font-size: 12px;
  line-height: 1.45;
  margin: 4px 0 0;
}

.zone-swatch {
  border-radius: 999px;
  height: 18px;
  width: 18px;
}

.focus-line {
  background: var(--soft);
  border-radius: 8px;
  color: var(--accent);
  font-size: 13px;
  font-weight: 900;
  padding: 9px 10px;
}

.region-table {
  border: 1px solid var(--line);
  border-radius: 8px;
  display: grid;
  overflow: hidden;
}

.region-table div {
  align-items: center;
  border-bottom: 1px solid var(--line);
  display: grid;
  gap: 8px;
  grid-template-columns: 52px 1fr;
  padding: 8px 10px;
}

.region-table div:last-child {
  border-bottom: 0;
}

.region-table .is-selected {
  background: #fff5cf;
}

.region-table span {
  color: var(--muted);
  font-size: 12px;
  font-weight: 900;
}

.region-table b {
  font-size: 13px;
}

.sign-grid {
  display: grid;
  gap: 8px;
  grid-template-columns: 1fr 1fr;
}

.sign-grid div {
  border: 1px solid var(--line);
  border-radius: 8px;
  display: grid;
  gap: 4px;
  padding: 8px;
}

.sign-grid strong {
  font-size: 12px;
}

.sign-grid span {
  color: var(--muted);
  font-size: 11px;
  line-height: 1.4;
}

.notice {
  color: var(--accent-2);
  font-size: 12px;
  font-weight: 800;
  line-height: 1.5;
  margin: auto 0 0;
}

.iris-intro-card,
.wellness-card,
.disclaimer-card,
.health-frame-card {
  background:
    linear-gradient(145deg, rgba(32, 245, 240, 0.08), transparent 38%),
    rgba(5, 9, 18, 0.88);
  border: 1px solid rgba(50, 215, 202, 0.28);
  border-radius: 14px;
  box-shadow: 0 18px 50px rgba(0, 0, 0, 0.32);
}

.iris-intro-card {
  display: grid;
  gap: 18px;
  grid-column: 1 / -1;
  grid-template-columns: minmax(0, 0.95fr) minmax(280px, 1.05fr);
  padding: 18px;
  transition: border-color 180ms ease, transform 180ms ease;
}

.iris-intro-card:hover,
.wellness-card:hover,
.disclaimer-card:hover {
  border-color: rgba(32, 245, 240, 0.55);
  transform: translateY(-1px);
}

.section-kicker {
  color: var(--accent);
  font-size: 12px;
  font-weight: 900;
}

.intro-copy {
  align-content: center;
  display: grid;
  gap: 14px;
}

.intro-copy h2 {
  color: #ffffff;
  font-size: 28px;
}

.intro-copy p,
.lung-map-card span,
.wellness-card p,
.disclaimer-card {
  color: #d7e6e4;
  line-height: 1.75;
}

.lung-map-card {
  display: grid;
  gap: 12px;
  margin: 0;
}

.lung-map-card img {
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 12px;
  display: block;
  height: auto;
  max-width: 100%;
  width: 100%;
}

.center-image-panel {
  align-items: center;
  grid-column: 1 / -1;
  justify-items: center;
}

.center-image-panel .lung-map-card {
  max-width: 980px;
  width: 100%;
}

.lung-map-card figcaption {
  display: grid;
  gap: 6px;
}

.lung-map-card strong {
  color: #ffffff;
  font-size: 18px;
}

.wellness-card,
.disclaimer-card {
  display: grid;
  gap: 10px;
  grid-column: 1 / -1;
  padding: 18px;
}

.wellness-card p,
.disclaimer-card {
  margin: 0;
}

.disclaimer-card {
  color: #f3d58a;
  font-weight: 800;
}

.health-page {
  background: #03050b;
  min-height: 100vh;
  overflow-x: hidden;
}

.health-shell {
  display: grid;
  gap: 16px;
  margin: 0 auto;
  max-width: 1120px;
  min-height: 100vh;
  padding: 16px;
}

.health-topbar {
  align-items: center;
  background: rgba(5, 9, 18, 0.92);
  border: 1px solid rgba(50, 215, 202, 0.28);
  border-radius: 14px;
  display: flex;
  justify-content: space-between;
  padding: 12px 14px;
  position: sticky;
  top: 10px;
  z-index: 10;
}

.home-btn {
  background: var(--accent);
  border-color: var(--accent);
  color: #ffffff;
  font-weight: 900;
}

.health-form-card {
  background: rgba(5, 9, 18, 0.96);
  border: 1px solid rgba(50, 215, 202, 0.28);
  border-radius: 12px;
  overflow: hidden;
}

.health-form-heading {
  border-bottom: 1px solid rgba(50, 215, 202, 0.22);
  padding: 28px clamp(18px, 4vw, 42px);
}

.health-form-heading h1,
.health-form-heading p {
  margin: 0;
}

.health-form-heading h1 {
  color: #ffffff;
  font-size: 30px;
  margin-bottom: 10px;
}

.health-form-heading > p:last-child {
  color: #aebbc8;
  line-height: 1.7;
}

.health-test-form {
  display: grid;
}

.test-section {
  padding: 28px clamp(18px, 4vw, 42px);
}

.test-section + .test-section,
#questionSections + .test-section,
#questionSections .test-section:first-child {
  border-top: 1px solid rgba(133, 154, 173, 0.2);
}

.section-heading {
  align-items: center;
  display: flex;
  gap: 12px;
  margin-bottom: 22px;
}

.section-heading span {
  color: #32d7ca;
  font-size: 13px;
  font-weight: 900;
}

.section-heading h2 {
  color: #ffffff;
  font-size: 21px;
  margin: 0;
}

.basic-fields {
  align-items: stretch;
  display: grid;
  gap: 14px;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.basic-fields > .question-item {
  border-bottom: 0;
  min-width: 0;
  padding: 0;
}

.basic-fields > .text-field {
  min-width: 0;
}

.basic-fields .choice-row,
.basic-fields .choice-row label,
.basic-fields .text-field input {
  height: 48px;
  min-height: 48px;
}

.question-list {
  display: grid;
  gap: 0;
}

.question-item {
  border: 0;
  border-bottom: 1px solid rgba(133, 154, 173, 0.14);
  display: grid;
  gap: 12px;
  margin: 0;
  padding: 18px 0;
}

.question-item:first-child {
  padding-top: 0;
}

.question-item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.question-item legend,
.text-field {
  color: #eef5f7;
  font-size: 15px;
  font-weight: 800;
}

.question-item b,
.text-field b {
  color: #32d7ca;
}

.choice-row {
  display: grid;
  gap: 8px;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.choice-row.compact {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.choice-row label,
.diagnosis-options label {
  align-items: center;
  background: rgba(14, 25, 39, 0.78);
  border: 1px solid rgba(133, 154, 173, 0.25);
  border-radius: 7px;
  color: #cbd5df;
  cursor: pointer;
  display: flex;
  gap: 8px;
  min-height: 48px;
  padding: 9px 12px;
  transition: background 160ms ease, border-color 160ms ease;
}

.choice-row label:hover,
.diagnosis-options label:hover {
  background: rgba(23, 48, 60, 0.9);
  border-color: rgba(50, 215, 202, 0.58);
}

.choice-row input,
.diagnosis-options input {
  accent-color: #32d7ca;
  flex: 0 0 auto;
}

.text-field {
  display: block;
}

.text-field input,
.text-field textarea {
  background: rgba(14, 25, 39, 0.78);
  border: 1px solid rgba(133, 154, 173, 0.3);
  border-radius: 7px;
  color: #ffffff;
  box-sizing: border-box;
  display: block;
  font: inherit;
  margin-top: 8px;
  min-width: 0;
  padding: 12px;
  width: 100%;
}

.text-field input:focus,
.text-field textarea:focus {
  border-color: #32d7ca;
  outline: 2px solid rgba(50, 215, 202, 0.16);
}

.diagnosis-field {
  padding-top: 0;
}

.expanded-field {
  border-top: 1px solid rgba(133, 154, 173, 0.18);
  margin-top: 24px;
  padding-top: 24px;
}

.diagnosis-options {
  display: grid;
  gap: 8px;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.diagnosis-options label {
  min-height: 52px;
}

.wide-checklist label {
  align-items: flex-start;
  line-height: 1.35;
}

.supplemental-fields {
  display: grid;
  gap: 14px;
  grid-template-columns: 1fr 1fr;
  margin-top: 24px;
}

.supplemental-fields .text-field input {
  min-height: 48px;
}

.supplemental-fields .text-field textarea {
  min-height: 104px;
  resize: vertical;
}

.symptoms-field {
  margin-top: 22px;
}

.symptoms-field textarea {
  min-height: 112px;
  resize: vertical;
}

.field-error {
  color: #ff9f9f;
  font-size: 13px;
  margin: 0;
}

.health-disclaimer {
  border-top: 1px solid rgba(133, 154, 173, 0.2);
  color: #e5c778;
  margin: 0;
  padding: 20px clamp(18px, 4vw, 42px);
  text-align: center;
}

.health-submit-bar {
  align-items: center;
  background: rgba(8, 15, 26, 0.98);
  border-top: 1px solid rgba(50, 215, 202, 0.25);
  display: flex;
  gap: 16px;
  justify-content: flex-end;
  padding: 16px clamp(18px, 4vw, 42px);
  position: sticky;
  bottom: 0;
}

.health-submit-bar p {
  color: #8fe3db;
  margin: 0 auto 0 0;
}

.health-save-btn {
  background: #167c70;
  border-color: #32d7ca;
  color: #ffffff;
  font-weight: 900;
  min-width: 170px;
}

@media (max-width: 940px) {
  .app-shell {
    grid-template-columns: 1fr;
    padding: 8px 8px 190px;
  }

  .topbar {
    align-items: flex-start;
    flex-direction: column;
    padding: 14px;
  }

  .actions,
  .actions button,
  .file-button {
    width: 100%;
  }

  .panel-block:has(#centerX) {
    bottom: 10px;
    grid-template-columns: 1fr 1fr;
    left: 10px;
    right: 10px;
  }

  .panel-block:has(#centerX) h2,
  .panel-block:has(#centerX) .button-row {
    grid-column: 1 / -1;
  }

  .iris-intro-card {
    grid-template-columns: 1fr;
  }

  .intro-copy h2 {
    font-size: 24px;
  }

  .health-page {
    overflow: auto;
  }

  .health-shell {
    min-height: 100vh;
    padding: 8px;
  }

  .health-topbar {
    align-items: stretch;
    flex-direction: column;
    gap: 10px;
  }

  .health-topbar {
    position: static;
  }

  .basic-fields,
  .diagnosis-options,
  .supplemental-fields {
    grid-template-columns: 1fr 1fr;
  }

  .choice-row {
    grid-template-columns: 1fr 1fr;
  }

  .health-submit-bar {
    align-items: stretch;
    flex-direction: column;
  }

  .health-save-btn {
    width: 100%;
  }
}

@media (max-width: 520px) {
  .basic-fields,
  .diagnosis-options,
  .supplemental-fields,
  .choice-row,
  .choice-row.compact {
    grid-template-columns: 1fr;
  }

  .test-section {
    padding-block: 22px;
  }

}

body:has(#authScreen:not([hidden])) {
  background: #03050b;
}

.auth-screen {
  align-items: flex-start;
  background:
    radial-gradient(circle at 50% 28%, rgba(30, 211, 205, 0.16), transparent 22%),
    linear-gradient(180deg, #03040a 0%, #060913 52%, #020307 100%);
  color: #f8f4ea;
  justify-content: center;
  min-height: 100vh;
  overflow: auto;
  padding: 10px;
}

.auth-card {
  background:
    linear-gradient(180deg, rgba(5, 8, 18, 0.45), rgba(3, 4, 9, 0.92)),
    #050711;
  border: 1px solid rgba(192, 164, 91, 0.22);
  border-radius: 6px;
  box-shadow: 0 28px 90px rgba(0, 0, 0, 0.7);
  gap: 22px;
  max-width: 420px;
  min-height: calc(100vh - 20px);
  overflow: hidden;
  padding: 28px 26px 34px;
  position: relative;
}

.auth-card::before,
.auth-card::after {
  border: 1px solid rgba(255, 210, 126, 0.12);
  content: "";
  inset: 8px;
  pointer-events: none;
  position: absolute;
}

.auth-card::after {
  inset: 14px;
  border-color: rgba(92, 225, 214, 0.08);
}

.auth-brand,
.auth-title,
.auth-quote,
.auth-panel,
.auth-message,
.auth-footer {
  position: relative;
  z-index: 1;
}

.auth-brand {
  align-items: center;
  display: flex;
  gap: 12px;
  justify-content: center;
  margin-top: 6px;
}

.auth-logo {
  background:
    radial-gradient(circle, #050607 0 23%, #0da79c 24% 33%, #0b111b 34% 46%, transparent 47%),
    conic-gradient(from 20deg, #54eadc, #142845, #b88535, #15151e, #54eadc);
  border-radius: 50%;
  box-shadow: 0 0 24px rgba(61, 231, 218, 0.24);
  height: 38px;
  width: 38px;
}

.auth-brand strong {
  font-size: 15px;
  letter-spacing: 0;
}

.auth-title {
  text-align: center;
}

.auth-title h1 {
  color: #fff7e8;
  font-family: Georgia, "Noto Serif KR", serif;
  font-size: 34px;
  font-weight: 500;
  line-height: 1.25;
}

.auth-title p {
  color: rgba(248, 244, 234, 0.68);
  font-size: 14px;
  margin: 10px 0 0;
}

.auth-hero {
  background:
    linear-gradient(180deg, rgba(3, 4, 10, 0.04), rgba(3, 4, 10, 0.2)),
    url("assets/login-iris-main.jpg") center center / contain no-repeat;
  border-radius: 6px;
  height: 430px;
  margin: -6px auto -2px;
  max-width: 330px;
  width: 100%;
}

.auth-quote {
  color: rgba(255, 232, 184, 0.88);
  font-family: Georgia, "Noto Serif KR", serif;
  font-size: 15px;
  line-height: 1.8;
  margin: 0;
  text-align: center;
}

.auth-panel {
  background: rgba(10, 15, 27, 0.86);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 8px;
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.38);
  display: grid;
  gap: 14px;
  padding: 22px;
}

.auth-panel h2 {
  color: #ffffff;
  font-size: 22px;
  text-align: center;
}

.auth-copy {
  color: rgba(248, 244, 234, 0.62);
  font-size: 13px;
  text-align: center;
}

.auth-form {
  gap: 12px;
}

.auth-form label {
  color: rgba(248, 244, 234, 0.58);
  font-size: 12px;
}

.auth-form input {
  background: rgba(3, 5, 12, 0.82);
  border: 1px solid rgba(255, 255, 255, 0.14);
  border-radius: 6px;
  color: #fff;
  min-height: 46px;
}

.auth-form input::placeholder {
  color: rgba(248, 244, 234, 0.42);
}

.auth-form input:focus {
  border-color: #32d7ca;
  outline: 3px solid rgba(50, 215, 202, 0.14);
}

.auth-form .primary {
  background: linear-gradient(135deg, #35d7c6 0%, #7f38c9 100%);
  border: 0;
  border-radius: 6px;
  color: #fff;
  min-height: 50px;
}

.signup-form button {
  background: transparent;
  border-color: rgba(255, 255, 255, 0.12);
  color: #f8f4ea;
  min-height: 46px;
}

.auth-divider {
  color: rgba(248, 244, 234, 0.45);
}

.auth-divider::before,
.auth-divider::after {
  background: rgba(255, 255, 255, 0.08);
}

.auth-message {
  color: #66eadf;
  text-align: center;
}

.auth-footer {
  color: rgba(248, 244, 234, 0.48);
  display: grid;
  font-size: 11px;
  gap: 18px;
  line-height: 1.7;
  text-align: center;
}

.auth-footer strong {
  color: rgba(248, 244, 234, 0.68);
  font-size: 12px;
}

@media (max-width: 480px) {
  .auth-screen {
    padding: 4px;
  }

  .auth-card {
    border-radius: 4px;
    max-width: none;
    min-height: calc(100vh - 8px);
    padding: 24px 18px 30px;
  }

  .auth-title h1 {
    font-size: 30px;
  }

  .auth-hero {
    height: 330px;
    margin-left: -4px;
    margin-right: -4px;
  }

  .auth-panel {
    padding: 18px;
  }
}
/* 로그인 로고 이미지 적용 */
.auth-brand {
  justify-content: center !important;
}

.auth-brand .auth-logo {
  width: 320px !important;
  height: 70px !important;
  border-radius: 0 !important;
  background-image: url("assets/logo.jpg") !important;
  background-size: contain !important;
  background-position: center !important;
  background-repeat: no-repeat !important;
  box-shadow: none !important;
}

.auth-brand strong {
  display: none !important;
}
.control input[type="range"] {
  appearance: none;
  -webkit-appearance: none;
  height: 2px;
  border-radius: 999px;
  background: linear-gradient(90deg, #32d7ca, #7f38c9);
  outline: none;
}

.control input[type="range"]::-webkit-slider-thumb {
  appearance: none;
  -webkit-appearance: none;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: #ffffff;
  border: 2px solid #32d7ca;
  box-shadow: 0 0 10px rgba(50, 215, 202, 0.55);
  cursor: pointer;
}
