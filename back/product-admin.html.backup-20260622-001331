<!doctype html><html lang="ko"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>제품DB 관리자 설정</title>
<style>:root{color-scheme:dark;--line:#24475b;--text:#f5f7fa;--muted:#9db0bd;--cyan:#36d8d0;--gold:#e7b74e}*{box-sizing:border-box}body{margin:0;background:#05090f;color:var(--text);font-family:Arial,"Noto Sans KR",sans-serif}.page{width:min(1100px,100%);margin:auto;padding:22px}header{display:flex;justify-content:space-between;align-items:center}.button,button{min-height:42px;padding:0 15px;border:1px solid var(--line);border-radius:7px;background:#0b1522;color:var(--text);font-weight:700;text-decoration:none;cursor:pointer}.primary{background:var(--cyan);color:#061313}.card{margin-top:15px;padding:20px;border:1px solid var(--line);border-radius:8px;background:#0b1420}.form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}label{display:grid;gap:6px;color:var(--muted)}input,select,textarea{width:100%;padding:11px;border:1px solid #31556a;border-radius:6px;background:#09111c;color:var(--text)}textarea{min-height:90px}.wide{grid-column:1/-1}table{width:100%;border-collapse:collapse}th,td{padding:10px;border-bottom:1px solid var(--line);text-align:left}.muted{color:var(--muted)}@media(max-width:760px){.form-grid{grid-template-columns:1fr}.wide{grid-column:auto}header{align-items:stretch;flex-direction:column;gap:12px}.table-wrap{overflow:auto}}</style></head><body><main class="page">
<header><div><p class="muted">IRIS MAPPING LAB</p><h1>제품DB 관리자 설정</h1></div><div><a class="button" href="member-admin.html">회원 구독관리</a> <a class="button" href="shopping.html">쇼핑 화면</a></div></header>
<section class="card"><h2>제품군 설정</h2><form id="groupForm" class="form-grid"><label>제품군<select id="groupId"></select></label><label class="wide">추천 검색어<textarea id="groupKeywords" placeholder="한 줄에 하나"></textarea></label><button class="primary" type="submit">제품군 설정 저장</button></form></section>
<section class="card"><h2>추천제품DB 등록</h2><form id="productForm" class="form-grid"><label>제품군<select name="category" required></select></label><label>제품명<input name="name" required></label><label>브랜드<input name="brand" required></label><label class="wide">성분<input name="ingredient" required></label><label>도매가<input name="wholesalePrice" type="number" min="0"></label><label>판매가<input name="salePrice" type="number" min="0"></label><label>재고<input name="stock" type="number" min="0"></label><label>공급처<input name="supplier"></label><label class="wide">이미지 URL<input name="image" type="url"></label><button class="primary" type="submit">제품 저장</button></form><p id="status" class="muted"></p></section>
<section class="card"><h2>등록 제품</h2><div class="table-wrap"><table><thead><tr><th>제품군</th><th>제품명</th><th>브랜드</th><th>판매가</th><th>재고</th><th></th></tr></thead><tbody id="productRows"></tbody></table></div></section>
</main><script src="shopping-recommendation-db.js"></script><script src="product-admin.js"></script></body></html>
