function scanCellForReading(imageData, eye, hour, ring) {
  const centerDeg = (hour % 12) * 30 - 90;
  const startDeg = centerDeg - 12;
  const endDeg = centerDeg + 12;

  const innerR = eye.pupilRadius + ((eye.irisRadius - eye.pupilRadius) * (ring - 1)) / 6;
  const outerR = eye.pupilRadius + ((eye.irisRadius - eye.pupilRadius) * ring) / 6;

  const values = [];
  const sats = [];

  for (let deg = startDeg; deg <= endDeg; deg += 2) {
    const angle = (deg * Math.PI) / 180;

    for (let r = innerR; r <= outerR; r += 2) {
      const x = eye.centerX + Math.cos(angle) * r;
      const y = eye.centerY + Math.sin(angle) * r;
      const p = pixelAt(imageData, x, y);

      const lum = p.r * 0.2126 + p.g * 0.7152 + p.b * 0.0722;
      const max = Math.max(p.r, p.g, p.b);
      const min = Math.min(p.r, p.g, p.b);
      const sat = max === 0 ? 0 : (max - min) / max;

      values.push(lum);
      sats.push(sat);
    }
  }

  if (!values.length) return { line: 0, spot: 0, color: 0 };

  const avg = values.reduce((a, b) => a + b, 0) / values.length;
  const min = Math.min(...values);
  const max = Math.max(...values);
  const contrast = max - min;

  const dark = values.filter(v => v < avg - 30).length;
  const veryDark = values.filter(v => v < avg - 48).length;

  const satAvg = sats.reduce((a, b) => a + b, 0) / sats.length;
  const satSpread = Math.max(...sats) - Math.min(...sats);

  const line = clamp(Math.round(contrast * 0.9 + dark * 0.45), 0, 100);
  const spot = clamp(Math.round(veryDark * 2.1 + (255 - min) * 0.16), 0, 100);
  const color = clamp(Math.round(satAvg * 70 + satSpread * 80 + contrast * 0.12), 0, 100);

  return { line, spot, color };
}
