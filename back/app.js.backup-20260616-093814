}

function normalizePairView() {
  if (!state.eyes.right.image || !state.eyes.left.image) return;

  normalizeEyeView(state.eyes.right, NORMALIZED_IRIS_RADIUS, false);
  normalizeEyeView(state.eyes.left, NORMALIZED_IRIS_RADIUS, true);

  applyLeftEyeAutoOffset();
}

function normalizeEyeView(eye, targetRadius, keepPupilSize = false) {
  if (!eye.image || !Number.isFinite(eye.irisRadius) || eye.irisRadius <= 0) return;

  const oldBounds = eye.imageBounds;
  const scale = targetRadius / eye.irisRadius;

  const imageCenterX = (eye.centerX - oldBounds.x) / oldBounds.width;
  const imageCenterY = (eye.centerY - oldBounds.y) / oldBounds.height;

  const width = oldBounds.width * scale;
  const height = oldBounds.height * scale;

  eye.imageBounds = {
    x: NORMALIZED_CENTER_X - imageCenterX * width,
    y: NORMALIZED_CENTER_Y - imageCenterY * height,
    width,
    height,
    scale: oldBounds.scale * scale
  };

  eye.centerX = NORMALIZED_CENTER_X;
  eye.centerY = NORMALIZED_CENTER_Y;

  if (!keepPupilSize) {
    eye.pupilRadius = Math.max(22, Math.min(eye.pupilRadius * scale, targetRadius * 0.45));
  } else {
    eye.pupilRadius = NORMALIZED_PUPIL_RADIUS;
  }

  eye.irisRadius = targetRadius;
  eye.markers = [];
  eye.selected = null;
}

function applyLeftEyeAutoOffset() {
  const eye = state.eyes.left;
  if (!eye.image) return;

  const zoomedWidth = eye.imageBounds.width * LEFT_EYE_AUTO_ZOOM;
  const zoomedHeight = eye.imageBounds.height * LEFT_EYE_AUTO_ZOOM;

  eye.imageBounds.x = eye.centerX - (eye.centerX - eye.imageBounds.x) * LEFT_EYE_AUTO_ZOOM;
  eye.imageBounds.y = eye.centerY - (eye.centerY - eye.imageBounds.y) * LEFT_EYE_AUTO_ZOOM;
  eye.imageBounds.width = zoomedWidth;
  eye.imageBounds.height = zoomedHeight;
  eye.imageBounds.scale *= LEFT_EYE_AUTO_ZOOM;

  alignLeftEyePupilToOverlay(eye);

  // 좌안 사진 강제 위치 보정
  eye.imageBounds.x += 70;
  eye.imageBounds.y += 150;
}

