let lineStartPoint = null;

canvas.addEventListener("click", (event) => {
  const hit = eventToCanvasPoint(event);

  if (hit.eyeKey) {
    state.activeEye = hit.eyeKey;
    updateActiveEye();
    syncControls();
  }

  const eye = currentEye();
  if (!eye.image) return;

  const point = { x: hit.x, y: hit.y };
  const match = resolvePoint(point.x, point.y);
  if (!match) return;

  // 첫 번째 클릭 = 선 시작점
  if (!lineStartPoint) {
    lineStartPoint = point;
    eye.selected = point;
    renderSelection({
      ...match,
      organ: "선 시작점 선택됨. 끝점을 클릭하세요."
    });
    draw();
    return;
  }

  // 두 번째 클릭 = 선 끝점
  const lineEndPoint = point;
  const pathMatches = resolveLinePath(lineStartPoint, lineEndPoint);

  eye.markers.push({
    id: crypto.randomUUID(),
    type: "선",
    start: lineStartPoint,
    end: lineEndPoint,
    x: Math.round(lineEndPoint.x),
    y: Math.round(lineEndPoint.y),
    codes: pathMatches.map((item) => item.code),
    organs: pathMatches.map((item) => item.organ),
    ...match
  });

  lineStartPoint = null;

  renderSelection({
    ...match,
    organ: `선 통과 위치: ${pathMatches.map((item) => item.code).join(" → ")}`
  });

  renderMarkers();
  renderDetailMap(match);
  draw();
});

