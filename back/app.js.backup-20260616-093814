      const score = scanCellForReading(imageData, eye, hour, ring);

      if (score.line >= 72) {
        results.push({ code, type: "Line", score: score.line });
      }

      if (score.spot >= 78) {
        results.push({ code, type: "Spot", score: score.spot });
      }

      if (score.color >= 82) {
