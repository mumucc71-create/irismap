function updateCanvasLayout() {
  const shouldStack = window.innerWidth < 760;
  const nextWidth = shouldStack ? VIEW_WIDTH : VIEW_WIDTH * 2;
  const nextHeight = shouldStack ? VIEW_HEIGHT * 2 : VIEW_HEIGHT;

  state.stackedLayout = shouldStack;

  if (canvas.width !== nextWidth) canvas.width = nextWidth;
  if (canvas.height !== nextHeight) canvas.height = nextHeight;

  canvas.classList.toggle("is-stacked", shouldStack);
}

