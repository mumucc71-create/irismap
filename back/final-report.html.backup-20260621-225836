        const lifestyle=selected.lifestyleMatches.length?selected.lifestyleMatches.slice(0,5).map((item)=>`${item.label}(${list(item.value)})`).join(", "):"일치 생활습관 없음";
        const history=selected.historyMatches.length?selected.historyMatches.slice(0,4).map((item)=>`${item.name} ${item.score}%`).join(", "):"일치 병력 없음";
        return `<article class="integrated-rank"><h3>${index+1}순위 · ${escapeHtml(selected.name)} <span class="meta">우선점수 ${selected.score}</span></h3>
          <div class="iris-bubble"><strong>${escapeHtml(selected.name)}</strong><span>문진 일치도 ${selected.questionnaireMatchPercent===null?"확인 불가":selected.questionnaireMatchPercent+"%"}</span><span>관리 우선도 ${escapeHtml(selected.managementPriority)}</span></div><dl>
          <dt>후보 영역</dt><dd>${escapeHtml(group.candidateAreas.join(" / "))}</dd>
