    function renderIntegratedReading() {
      const target=document.querySelector("#integratedReading");
      const result=integratedResult;
      if(!result.results.length){
        target.innerHTML='<p class="empty">종합 관리 우선순위를 만들 수 있는 저장 자료가 없습니다. 라이프케어진단을 작성하고 필요한 자료를 저장해 주세요.</p>';
