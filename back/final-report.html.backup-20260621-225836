    function renderStatus() {
      const hasLifestyle=integratedResult.results.some((group)=>(group.selected.lifestyleMatches||[]).length);
      const items=[["문진",!!health],["유니버스 병력",Array.isArray(universeHistory)&&universeHistory.length>0],["생활습관",hasLifestyle],["홍채 교차확인",!!irisForAccount]];
