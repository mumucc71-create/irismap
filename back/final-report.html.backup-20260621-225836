          <dt>최종 부위</dt><dd><strong>${escapeHtml(selected.name)}</strong></dd>
          <dt>종합 해석</dt><dd>${escapeHtml(group.consultation)}</dd>
        </dl></article>`;
      }).join("");
      target.innerHTML=confidenceHtml+questionnaireWarning+`<p class="meta">${escapeHtml(confidence.notice)}</p>`+ranks;
    }

    function renderCombined() {
      const parts=["회원님의 문진, 생활습관, 과거 병력 정보를 종합 분석한 결과 현재 우선적으로 관리가 필요한 영역이 확인되었습니다."];
      if (healthTop.length) parts.push(`라이프케어진단에서는 <strong>${escapeHtml(healthTop.map((item)=>item.title).join(", "))}</strong> 관련 주의·불편 응답이 상대적으로 많이 확인됩니다.`);
      const lifestyleNames=integratedResult.results.flatMap((group)=>(group.selected.lifestyleMatches||[]).map((item)=>item.label));
      if(lifestyleNames.length)parts.push(`생활습관에서는 <strong>${escapeHtml([...new Set(lifestyleNames)].slice(0,5).join(", "))}</strong> 경향이 함께 확인됩니다.`);
      const latestUniverse=Array.isArray(universeHistory)?universeHistory.at(-1):null;
