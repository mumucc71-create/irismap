const subscriptionAnalysis=IrisCareEngine.analyze();
const subscriptionKey=subscriptionAnalysis.phone?"irisSubscription:"+subscriptionAnalysis.phone:"irisSubscription";
const vipKey=subscriptionAnalysis.phone?"irisVipMembership:"+subscriptionAnalysis.phone:"irisVipMembership";
const savedSubscription=readSubscription(subscriptionKey)||{};
let vipMembership=readSubscription(vipKey)||{};
const uniqueSubscription=(items)=>[...new Set(items.filter(Boolean))];
const currentBox=uniqueSubscription(subscriptionAnalysis.primary.flatMap((item)=>item.box)).slice(0,8);
const currentDate=new Date();
const subscriptionStart=savedSubscription.startDate?new Date(savedSubscription.startDate):currentDate;
const subscriptionMonths=Math.max(0,(currentDate.getFullYear()-subscriptionStart.getFullYear())*12+currentDate.getMonth()-subscriptionStart.getMonth());
const nextScanDate=new Date(subscriptionStart);
nextScanDate.setMonth(subscriptionStart.getMonth()+(Math.floor(subscriptionMonths/4)+1)*4);
const readingHistory=readSubscription(subscriptionAnalysis.phone?"irisReadingHistory:"+subscriptionAnalysis.phone:"")||[];

function readSubscription(key){try{return JSON.parse(localStorage.getItem(key)||"null")}catch(_){return null}}
function escapeSubscription(value){return String(value??"").replace(/[&<>"']/g,(c)=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]))}

if(!vipMembership.active&&subscriptionAnalysis.phone){
  const universeHistory=readSubscription(`UniverseReportDB:${subscriptionAnalysis.phone}`);
  if(Array.isArray(universeHistory)&&universeHistory.length){
    const now=new Date().toISOString();
    vipMembership={active:true,tier:"보험 VIP",activatedAt:now,updatedAt:now,source:"기존 유니버스 PDF 리포트",benefits:["유니버스 리포트","라이프진단","보장분석","홍채 결과 저장","문진 결과 저장","건강박스 1회 무료 제공"],healthBox:{benefit:"1회 무료 제공",status:"미사용",composition:"운영자 직접 구성",items:[],updatedAt:now}};
    localStorage.setItem(vipKey,JSON.stringify(vipMembership));
  }
}

const dashboardItems=[
  ["구독 상태",savedSubscription.status||"미등록"],["구독 개월 수",subscriptionMonths+"개월"],
  ["다음 촬영 예정일",nextScanDate.toLocaleDateString("ko-KR")],["최근 건강유형",subscriptionAnalysis.type],
  ["최근 건강박스",(savedSubscription.box||currentBox).join(", ")||"미구성"],
  ["최근 관찰 결과",subscriptionAnalysis.primary.map((item)=>item.title).join(", ")||"자료 없음"]
];
document.querySelector("#dashboard").innerHTML=dashboardItems.map(([label,value])=>'<div class="metric"><strong>'+escapeSubscription(label)+'</strong><p>'+escapeSubscription(value)+'</p></div>').join("");
document.querySelector("#profileSummary").innerHTML="현재 자료를 종합한 건강유형은 <strong>"+escapeSubscription(subscriptionAnalysis.type)+"</strong>입니다. 관리 우선순위는 "+escapeSubscription(subscriptionAnalysis.primary.map((item)=>item.title).join(", ")||"기본 생활관리")+"입니다.";
document.querySelector("#box").innerHTML=currentBox.map((item)=>'<div class="box-item">'+escapeSubscription(item)+'</div>').join("")||"<p>건강박스를 구성할 분석 자료가 없습니다.</p>";
renderVipBenefit();
renderReadingComparison();
document.querySelectorAll(".plan-button").forEach((button)=>button.addEventListener("click",()=>{
  const payload={status:"관리 중",plan:button.dataset.plan,startDate:savedSubscription.startDate||new Date().toISOString(),updatedAt:new Date().toISOString(),healthType:subscriptionAnalysis.type,box:currentBox,months:subscriptionMonths,scoreSnapshot:subscriptionAnalysis.scores};
  localStorage.setItem(subscriptionKey,JSON.stringify(payload));
  if(subscriptionAnalysis.phone){
    const boxHistoryKey=`irisHealthBoxHistory:${subscriptionAnalysis.phone}`;
    const boxHistory=readSubscription(boxHistoryKey)||[];
    boxHistory.push({recordedAt:new Date().toISOString(),plan:button.dataset.plan,healthType:subscriptionAnalysis.type,box:currentBox});
    localStorage.setItem(boxHistoryKey,JSON.stringify(boxHistory.slice(-12)));
  }
  document.querySelector("#saveStatus").textContent=button.dataset.plan+" 플랜이 이 브라우저의 회원 기록에 저장되었습니다. 실제 결제나 주문은 발생하지 않습니다.";
}));

function readingCodes(record){const source=record?.allObservations||{right:record?.right||[],left:record?.left||[]};return new Set([...(source.right||[]),...(source.left||[])].map((item)=>item.code+" "+(item.area||"")))}
function renderVipBenefit(){
  const statusTarget=document.querySelector("#vipStatus"),benefitTarget=document.querySelector("#vipBenefits"),boxTarget=document.querySelector("#vipBoxStatus");
  if(!statusTarget||!benefitTarget||!boxTarget)return;
  if(!vipMembership.active){
    statusTarget.innerHTML='<p class="muted">유니버스 병력분석 PDF 업로드를 완료하면 보험 VIP 회원과 건강박스 1회 무료 혜택이 활성화됩니다.</p><a class="button" href="universe.html">유니버스 PDF 업로드</a>';
    benefitTarget.innerHTML="";
    boxTarget.innerHTML="";
    return;
  }
  const benefits=vipMembership.benefits||["유니버스 리포트","라이프진단","보장분석","홍채 결과 저장","문진 결과 저장","건강박스 1회 무료 제공"];
  const healthBox=vipMembership.healthBox||{status:"미사용",composition:"운영자 직접 구성"};
  statusTarget.innerHTML='<p><strong>VIP 활성화 완료</strong><br>축하합니다. 회원님께 건강박스 1회 무료 제공 혜택이 지급되었습니다.</p>';
  benefitTarget.innerHTML=benefits.map((item)=>'<span>'+escapeSubscription(item)+'</span>').join("");
  boxTarget.innerHTML='<p><strong>건강박스 상태</strong> <span class="status-pill">'+escapeSubscription(healthBox.status||"미사용")+'</span></p><p class="muted">'+escapeSubscription(healthBox.composition||"회원 상태를 참고하여 운영자가 직접 구성")+' · 건강식품, 건강차, 건강간식, 건강도서, 체험권, 할인권 등에서 구성됩니다.</p>';
}
function renderReadingComparison(){const latest=readingHistory[readingHistory.length-1],previous=readingHistory[readingHistory.length-2];if(!latest||!previous){document.querySelector("#newAreas").textContent="비교하려면 서로 다른 날짜의 판독 결과가 2회 이상 필요합니다.";document.querySelector("#reducedAreas").textContent="비교 자료 부족";document.querySelector("#stableAreas").textContent="비교 자료 부족";return}const current=readingCodes(latest),past=readingCodes(previous);const added=[...current].filter((code)=>!past.has(code));const reduced=[...past].filter((code)=>!current.has(code));const stable=[...current].filter((code)=>past.has(code));document.querySelector("#newAreas").textContent=added.join(", ")||"새 항목 없음";document.querySelector("#reducedAreas").textContent=reduced.join(", ")||"줄어든 항목 없음";document.querySelector("#stableAreas").textContent=stable.join(", ")||"유지 항목 없음";}
