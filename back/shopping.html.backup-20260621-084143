<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>쇼핑 선별 추천 | IRIS MAPPING LAB</title>
  <style>
    :root{color-scheme:dark;--bg:#05090f;--panel:#0b1420;--line:#24475b;--text:#f5f7fa;--muted:#9db0bd;--cyan:#36d8d0;--gold:#e7b74e}
    *{box-sizing:border-box}body{margin:0;min-height:100vh;background:linear-gradient(180deg,#07121b,#030609);color:var(--text);font-family:Arial,"Noto Sans KR",sans-serif}.page{width:min(1180px,100%);margin:auto;padding:22px}header{display:flex;justify-content:space-between;align-items:center;gap:18px;padding:18px 0 22px;border-bottom:1px solid var(--line)}.brand{color:var(--cyan);font-size:13px;font-weight:800;letter-spacing:.08em}h1{margin:7px 0 0;font-size:clamp(28px,4vw,42px)}h2{margin:0 0 14px;font-size:21px}h3{margin:0 0 8px;color:var(--gold)}p{line-height:1.65}.actions{display:flex;gap:9px}.button{display:inline-flex;align-items:center;justify-content:center;min-height:42px;padding:0 16px;border:1px solid var(--line);border-radius:7px;background:#0b1522;color:var(--text);font-weight:700;text-decoration:none}.summary,.category,.conditions,.empty{margin-top:16px;padding:20px;border:1px solid var(--line);border-radius:8px;background:rgba(10,19,31,.94)}.category-grid,.product-grid{display:grid;gap:12px}.category-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.product-grid{grid-template-columns:repeat(3,minmax(0,1fr));margin-top:14px}.product{padding:16px;border:1px solid #31556a;border-radius:7px;background:#09111c}.tag{display:inline-block;margin:3px 5px 3px 0;padding:5px 8px;border:1px solid #2d7181;border-radius:5px;color:var(--cyan);font-size:13px}.search-link{display:inline-flex;margin-top:10px;color:#061111;background:var(--cyan);padding:9px 12px;border-radius:6px;font-weight:800;text-decoration:none}.muted,.notice{color:var(--muted)}.warning{border-left:3px solid var(--gold);padding:14px 16px;background:#111018;line-height:1.6}.conditions ol{columns:2;line-height:1.75}.empty{text-align:center}.empty a{color:var(--cyan)}
    @media(max-width:820px){.category-grid,.product-grid{grid-template-columns:1fr}.conditions ol{columns:1}}@media(max-width:620px){.page{padding:12px}header{align-items:stretch;flex-direction:column}.actions,.actions>*{width:100%}}
  </style>
</head>
<body>
  <main class="page">
    <header><div><div class="brand">IRIS MAPPING LAB</div><h1>쇼핑하기 선별 추천</h1></div><nav class="actions"><a class="button" href="final-report.html">최종 판독</a><a class="button" href="index.html">메인 화면</a></nav></header>
    <section class="summary"><h2>회원 자료 기반 추천</h2><div id="sourceSummary"></div><div id="safetyWarning"></div></section>
    <section id="recommendations" class="category-grid"></section>
    <section class="conditions"><h2>제품 선별 기준</h2><ol id="conditions"></ol><p class="notice">상품명·가격·후기·평점의 실시간 자동 수집은 쇼핑몰 공식 API 연결 후 적용됩니다. 현재 화면은 성분표를 확인하기 위한 비교 후보와 검색어를 제공합니다.</p></section>
    <p class="warning">본 추천은 건강관리 제품 선택을 돕기 위한 참고 정보입니다. 증상이 심하거나 반복되면 의료기관 진료가 필요합니다. 임신·수유 중이거나 약을 복용 중이거나 간·신장·심혈관 질환이 있는 경우 구매 전에 의사 또는 약사와 상담하세요.</p>
  </main>
  <script src="shopping-recommendation-db.js"></script>
  <script>
    const db=window.shoppingRecommendationDB;
    const phone=normalizePhone(localStorage.getItem("irisMappingSession"));
    const health=phone?readJson(`irisHealthTest:${phone}`):null;
    const iris=readJson("irisReadingResult");
    const labels=health?.answerLabels||{};
    const healthText=collectHealthText(health);
    const irisText=collectIrisText(iris);
    const signalText=`${healthText} ${irisText}`;
    const selected=selectProductGroups(signalText).slice(0,5);
    renderSources(); renderRecommendations(); renderConditions();

    function normalizePhone(value){let digits=String(value||"").replace(/\D/g,"");if(digits.length===10&&digits.startsWith("10"))digits=`0${digits}`;return digits}
    function readJson(key){try{return JSON.parse(localStorage.getItem(key)||"null")}catch(_){return null}}
    function escapeHtml(value){return String(value??"").replace(/[&<>"']/g,(c)=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]))}
    function hasHealthSignal(answer){const values=Array.isArray(answer)?answer:[answer];return values.some((value)=>{const text=String(value??"").trim();return text&&!['아니오','전혀 아니다','없음','해당 없음','정상','모름','잘 모름','미기록','특별히 없음','통증 없음','환경노출 없음','알레르기 없음'].includes(text)})}
    function collectHealthText(data){if(!data)return"";return Object.entries(data).flatMap(([group,value])=>value&&typeof value==="object"&&!Array.isArray(value)&&group!=="answerLabels"?Object.entries(value).filter(([,answer])=>hasHealthSignal(answer)).flatMap(([name,answer])=>[labels[name]||name,Array.isArray(answer)?answer.join(" "):answer]):[]).join(" ")}
    function collectIrisText(data){if(!data)return"";const source=data.allObservations||{right:data.right||[],left:data.left||[]};return [...(source.right||[]),...(source.left||[])].map((item)=>`${item.code} ${item.area||""} ${item.consultation||""}`).join(" ")}
    function selectProductGroups(text){return db.productGroupDB.map((group)=>({...group,score:group.keywords.reduce((sum,key)=>sum+(text.includes(key)?1:0),0)})).filter((group)=>group.score>0).sort((a,b)=>b.score-a.score)}
    function renderSources(){const complete=[health&&"라이프케어진단",iris&&"홍채 판독"].filter(Boolean);document.querySelector("#sourceSummary").innerHTML=complete.length?`<p><strong>반영 자료:</strong> ${complete.join(", ")}</p><p class="muted">저장된 응답과 관찰 영역에서 반복되는 관리 키워드를 우선 반영했습니다.</p>`:'<p>추천에 사용할 저장 자료가 없습니다. <a href="health.html">라이프케어진단</a>과 홍채 판독을 먼저 진행해 주세요.</p>';const caution=/(임신|수유|약 복용|복용 중|간질환|간수치|신장질환|고혈압|심장질환|항응고)/.test(signalText);document.querySelector("#safetyWarning").innerHTML=caution?'<p class="warning"><strong>복용 전 확인 필요:</strong> 임신·약 복용·질환 관련 응답이 확인되어 제품 구매 전에 의료진 또는 약사 상담이 우선입니다.</p>':''}
    function renderRecommendations(){const target=document.querySelector("#recommendations");if(!selected.length){target.innerHTML='<div class="empty"><h2>추천 제품군 없음</h2><p>현재 저장 자료만으로 특정 제품군을 정하지 않았습니다.</p></div>';return}target.innerHTML=selected.map((group)=>{const terms=db.searchKeywordDB[group.id]||[];const products=db.recommendationProductDB.filter((item)=>item.category===group.id).slice(0,5);return `<article class="category"><h2>${escapeHtml(group.title)}</h2><p>${escapeHtml(group.message)}</p><h3>추천 검색어</h3><div>${terms.map((term)=>`<span class="tag">${escapeHtml(term)}</span>`).join("")}</div><div class="product-grid">${products.map((product,index)=>`<section class="product"><h3>${index+1}. ${escapeHtml(product.name)}</h3><p><strong>핵심 성분:</strong> ${escapeHtml(product.ingredient)}</p><p class="muted">${escapeHtml(product.reason)}</p><a class="search-link" href="https://search.shopping.naver.com/search/all?query=${encodeURIComponent(terms[index%terms.length]||group.title)}" target="_blank" rel="noopener noreferrer">쇼핑 검색</a></section>`).join("")}</div></article>`}).join("")}
    function renderConditions(){document.querySelector("#conditions").innerHTML=db.selectionConditionDB.map((condition)=>`<li>${escapeHtml(condition)}</li>`).join("")}
  </script>
</body>
</html>
