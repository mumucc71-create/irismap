    const favoriteFoods = ["채소·나물", "과일", "육류", "생선·해산물", "유제품", "곡류·빵·면", "단 음식", "짠 음식", "매운 음식", "기름진 음식", "인스턴트·가공식품", "커피·카페인", "야식", "특별히 없음", "기타"];
    const allergies = ["음식", "약물", "꽃가루·먼지", "반려동물", "금속·화장품", "벌레", "알레르기 없음", "기타"];
    const diagnoses = ["고혈압", "당뇨", "이상지질혈증", "비만", "심장·부정맥·관상동맥질환", "뇌졸중·뇌혈관질환", "갑상선질환", "천식·만성폐질환", "간·지방간·간염", "담낭·담석", "췌장질환", "위염·궤양·역류", "과민성·염증성 장질환", "신장질환", "요로결석·방광질환", "전립선질환", "빈혈·혈액질환", "관절염·류마티스·자가면역질환", "디스크·척추질환", "골다공증", "신경계질환", "우울·불안·정신건강질환", "안과질환", "이비인후과질환", "피부질환", "알레르기질환", "자궁·난소·유방질환", "남성 생식기질환", "암", "감염성질환", "없음", "기타"];
    const painAreas = ["머리·얼굴", "눈·귀·턱", "목", "어깨", "가슴", "등", "허리", "상복부", "하복부·골반", "옆구리", "팔·팔꿈치", "손목·손", "엉덩이·고관절", "허벅지", "무릎", "종아리", "발목·발", "전신", "통증 없음", "기타"];

    function renderChecks(targetId, name, values) {
      document.querySelector(`#${targetId}`).innerHTML = values.map((value) => `<label><input type="checkbox" name="${name}" value="${value}"> ${value}</label>`).join("");
    }

    renderChecks("familyDiseaseOptions", "familyDiseases", familyDiseases);
    renderChecks("favoriteFoodOptions", "favoriteFoods", favoriteFoods);
    renderChecks("allergyOptions", "allergies", allergies);
    renderChecks("diagnosisOptions", "diagnoses", diagnoses);
    renderChecks("painAreaOptions", "painAreas", painAreas);

    const questionSections = document.querySelector("#questionSections");
    questionSections.innerHTML = sections.map((section, index) => `
      <section class="test-section">
        <div class="section-heading"><span>${String(index + 5).padStart(2, "0")}</span><h2>${section.title}</h2></div>
        <div class="question-list">
          ${section.questions.map(([name, question, options]) => `
            <fieldset class="question-item">
              <legend>${question} <b>*</b></legend>
              <div class="choice-row">
                ${options.map((option, optionIndex) => `<label><input type="radio" name="${name}" value="${option}" ${optionIndex === 0 ? "required" : ""}><span>${option}</span></label>`).join("")}
              </div>
            </fieldset>
          `).join("")}
        </div>
      </section>
    `).join("");
    document.querySelector("#conditionNumber").textContent = String(sections.length + 5).padStart(2, "0");

    const form = document.querySelector("#healthTestForm");
    const saveStatus = document.querySelector("#healthSaveStatus");

    function setupCheckboxGroup(name, noneValue, errorSelector) {
      const inputs = [...document.querySelectorAll(`[name="${name}"]`)];
      const noneInput = inputs.find((input) => input.value === noneValue);
      const error = document.querySelector(errorSelector);
      inputs.forEach((input) => input.addEventListener("change", () => {
        if (input === noneInput && input.checked) inputs.forEach((item) => { if (item !== noneInput) item.checked = false; });
        else if (input.checked && noneInput) noneInput.checked = false;
        error.hidden = inputs.some((item) => item.checked);
      }));
      return { name, inputs, error };
    }

    const checkboxGroups = [
      setupCheckboxGroup("familyDiseases", "가족력 없음", "#familyDiseaseError"),
      setupCheckboxGroup("favoriteFoods", "특별히 없음", "#favoriteFoodError"),
      setupCheckboxGroup("allergies", "알레르기 없음", "#allergyError"),
      setupCheckboxGroup("diagnoses", "없음", "#diagnosisError"),
      setupCheckboxGroup("painAreas", "통증 없음", "#painAreaError")
    ];

    document.querySelector(".home-btn").addEventListener("click", () => { location.href = "index.html"; });

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const invalidGroup = checkboxGroups.find((group) => !group.inputs.some((input) => input.checked));
      if (invalidGroup) {
        invalidGroup.error.hidden = false;
        invalidGroup.inputs[0].focus();
        return;
      }
      if (!form.reportValidity()) return;
      const data = new FormData(form);
      const answers = Object.fromEntries(data.entries());
      checkboxGroups.forEach((group) => { answers[group.name] = data.getAll(group.name); });
      localStorage.setItem("irisHealthTestResult", JSON.stringify({ createdAt: new Date().toISOString(), answers }));
      saveStatus.textContent = "건강 문진 결과가 이 기기에 저장되었습니다.";
    });

    const savedResult = localStorage.getItem("irisHealthTestResult");
    if (savedResult) {
      try {
        const { answers } = JSON.parse(savedResult);
        Object.entries(answers || {}).forEach(([name, value]) => {
          const values = Array.isArray(value) ? value : [String(value)];
          document.querySelectorAll(`[name="${name}"]`).forEach((input) => {
            if (input.type === "radio" || input.type === "checkbox") input.checked = values.includes(input.value);
            else input.value = value;
          });
        });
        saveStatus.textContent = "이전에 저장한 응답을 불러왔습니다.";
      } catch (error) {
        localStorage.removeItem("irisHealthTestResult");
      }
    }
  </script>
</body>
</html>
