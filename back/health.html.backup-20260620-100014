<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>건강테스트 - IRIS MAPPING LAB</title>
  <link rel="stylesheet" href="styles.css?v=20260620-health-comprehensive-1">
</head>
<body class="health-page">
  <main class="health-shell">
    <header class="health-topbar">
      <div class="auth-brand main-brand">
        <span class="auth-logo" aria-hidden="true"></span>
        <strong>IRIS MAPPING LAB</strong>
      </div>
      <button class="home-btn" type="button">홈으로</button>
    </header>

    <section class="health-form-card">
      <div class="health-form-heading">
        <p class="eyebrow">COMPREHENSIVE HEALTH CHECK</p>
        <h1>종합 건강 문진</h1>
        <p>현재의 불편함뿐 아니라 가족력, 생활습관, 과거 병력까지 함께 기록하는 건강관리 참고용 문진입니다.</p>
      </div>

      <form id="healthTestForm" class="health-test-form">
        <section class="test-section" aria-labelledby="basicTitle">
          <div class="section-heading"><span>01</span><h2 id="basicTitle">기본정보</h2></div>
          <div class="basic-fields">
            <label class="text-field">이름 <b>*</b><input type="text" name="name" required placeholder="이름"></label>
            <fieldset class="question-item">
              <legend>성별 <b>*</b></legend>
              <div class="choice-row compact">
                <label><input type="radio" name="gender" value="남성" required><span>남성</span></label>
                <label><input type="radio" name="gender" value="여성"><span>여성</span></label>
              </div>
            </fieldset>
            <label class="text-field">나이 <b>*</b><input type="number" name="age" min="1" max="120" required placeholder="예: 45"></label>
            <label class="text-field">키(cm) <b>*</b><input type="number" name="height" min="50" max="250" step="0.1" required placeholder="예: 170"></label>
            <label class="text-field">몸무게(kg) <b>*</b><input type="number" name="weight" min="20" max="300" step="0.1" required placeholder="예: 65"></label>
            <label class="text-field">직업·주요 활동<input type="text" name="occupation" placeholder="예: 사무직, 자영업, 주부"></label>
          </div>
        </section>

        <section class="test-section" aria-labelledby="familyTitle">
          <div class="section-heading"><span>02</span><h2 id="familyTitle">가족 구성과 가족력</h2></div>
          <div class="supplemental-fields">
            <label class="text-field">형제자매 수 <b>*</b><input type="number" name="siblingCount" min="0" max="20" required placeholder="본인 제외 인원"></label>
            <label class="text-field">아버지의 질환·건강상태 <b>*</b><textarea name="fatherHistory" rows="3" required placeholder="질환명, 발병 나이, 현재 상태 / 없으면 없음"></textarea></label>
            <label class="text-field">어머니의 질환·건강상태 <b>*</b><textarea name="motherHistory" rows="3" required placeholder="질환명, 발병 나이, 현재 상태 / 없으면 없음"></textarea></label>
            <label class="text-field">형제자매의 질환·건강상태 <b>*</b><textarea name="siblingsHistory" rows="3" required placeholder="누가 어떤 질환이 있는지 / 없으면 없음"></textarea></label>
            <label class="text-field">조부모·가까운 혈족의 주요 질환<textarea name="extendedFamilyHistory" rows="3" placeholder="암, 뇌졸중, 심장질환, 유전질환 등"></textarea></label>
          </div>
          <fieldset class="question-item diagnosis-field">
            <legend>가족 중 진단받은 질환 <b>*</b></legend>
            <div id="familyDiseaseOptions" class="diagnosis-options wide-checklist"></div>
            <p id="familyDiseaseError" class="field-error" hidden>한 가지 이상 선택해 주세요.</p>
          </fieldset>
        </section>

        <section class="test-section" aria-labelledby="historyTitle">
          <div class="section-heading"><span>03</span><h2 id="historyTitle">어린 시절과 과거 병력</h2></div>
          <div class="supplemental-fields">
            <label class="text-field">어린 시절 크게 앓았던 병 <b>*</b><textarea name="childhoodIllness" rows="3" required placeholder="폐렴, 천식, 고열, 수술 등 / 없으면 없음"></textarea></label>
            <label class="text-field">입원했던 경험 <b>*</b><textarea name="hospitalHistory" rows="3" required placeholder="시기, 이유, 기간 / 없으면 없음"></textarea></label>
            <label class="text-field">수술·시술 경험 <b>*</b><textarea name="surgeryHistory" rows="3" required placeholder="수술명, 시기, 현재 상태 / 없으면 없음"></textarea></label>
            <label class="text-field">큰 사고·골절·화상·부상 경험 <b>*</b><textarea name="injuryHistory" rows="3" required placeholder="부위, 시기, 후유증 / 없으면 없음"></textarea></label>
            <label class="text-field">과거 감염병·반복 염증<textarea name="infectionHistory" rows="3" placeholder="결핵, 간염, 대상포진, 반복되는 염증 등"></textarea></label>
            <label class="text-field">과거 질환의 현재 상태<textarea name="pastConditionStatus" rows="3" placeholder="완치, 재발, 약 복용, 후유증 등"></textarea></label>
          </div>
        </section>

        <section class="test-section" aria-labelledby="lifestyleTitle">
          <div class="section-heading"><span>04</span><h2 id="lifestyleTitle">식습관·생활습관·알레르기</h2></div>
          <fieldset class="question-item diagnosis-field">
            <legend>좋아하거나 자주 먹는 음식 <b>*</b></legend>
            <div id="favoriteFoodOptions" class="diagnosis-options"></div>
            <p id="favoriteFoodError" class="field-error" hidden>한 가지 이상 선택해 주세요.</p>
          </fieldset>
          <div class="supplemental-fields">
            <label class="text-field">하루 식사 횟수<input type="number" name="mealCount" min="1" max="10" placeholder="예: 3"></label>
            <label class="text-field">하루 물 섭취량<input type="text" name="waterIntake" placeholder="예: 1.5L"></label>
            <label class="text-field">운동 종류와 횟수<textarea name="exerciseHabits" rows="3" placeholder="예: 걷기 주 3회, 30분"></textarea></label>
            <label class="text-field">흡연·음주 습관<textarea name="smokingAlcohol" rows="3" placeholder="종류, 양, 빈도 / 없으면 없음"></textarea></label>
          </div>
          <fieldset class="question-item diagnosis-field">
            <legend>알레르기 종류 <b>*</b></legend>
            <div id="allergyOptions" class="diagnosis-options"></div>
            <p id="allergyError" class="field-error" hidden>한 가지 이상 선택해 주세요.</p>
          </fieldset>
          <label class="text-field symptoms-field">구체적인 알레르기 원인과 반응<textarea name="allergyDetails" rows="3" placeholder="음식·약물 이름, 피부·호흡기 반응, 심한 정도"></textarea></label>
        </section>

        <div id="questionSections"></div>

        <section class="test-section" aria-labelledby="conditionTitle">
          <div class="section-heading"><span id="conditionNumber"></span><h2 id="conditionTitle">현재 질환·약물·주요 불편감</h2></div>
          <fieldset class="question-item diagnosis-field">
            <legend>현재까지 진단받은 질환 <b>*</b></legend>
            <div id="diagnosisOptions" class="diagnosis-options wide-checklist"></div>
            <p id="diagnosisError" class="field-error" hidden>한 가지 이상 선택해 주세요.</p>
          </fieldset>
          <div class="supplemental-fields">
            <label class="text-field">기타 진단 질환<input type="text" name="otherDiagnosis" placeholder="목록에 없는 질환"></label>
            <label class="text-field">현재 복용 중인 약·영양제 <b>*</b><textarea name="medications" rows="3" required placeholder="이름, 용량, 복용 횟수 / 없으면 없음"></textarea></label>
            <label class="text-field">가장 걱정되는 병 <b>*</b><input type="text" name="worriedDisease" required placeholder="현재 가장 걱정되는 질환"></label>
          </div>
          <fieldset class="question-item diagnosis-field expanded-field">
            <legend>통증을 느끼는 부위 <b>*</b></legend>
            <div id="painAreaOptions" class="diagnosis-options"></div>
            <p id="painAreaError" class="field-error" hidden>한 가지 이상 선택해 주세요.</p>
          </fieldset>
          <label class="text-field symptoms-field">통증의 기간·강도·양상<textarea name="painPattern" rows="3" placeholder="언제부터, 찌름·쑤심·화끈거림, 악화·완화 요인"></textarea></label>
          <label class="text-field symptoms-field">가장 불편한 증상 3가지 <b>*</b><textarea name="topSymptoms" rows="4" required placeholder="가장 불편한 순서대로 최대 3가지"></textarea></label>
          <label class="text-field symptoms-field">추가로 기록할 건강 문제<textarea name="additionalHealthNotes" rows="4" placeholder="질문에 없지만 꼭 알리고 싶은 내용"></textarea></label>
        </section>

        <p class="health-disclaimer">본 문진은 건강관리 참고용이며 의학적 진단이나 치료를 대체하지 않습니다. 갑작스러운 흉통, 호흡곤란, 마비, 의식 변화, 심한 출혈은 즉시 응급진료를 받으세요.</p>
        <div class="health-submit-bar">
          <p id="healthSaveStatus" role="status" aria-live="polite"></p>
          <button class="health-save-btn" type="submit">건강테스트 저장</button>
        </div>
      </form>
    </section>
  </main>

  <script>
