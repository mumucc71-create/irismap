<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>최종 종합 판독 | IRIS MAPPING LAB</title>
  <style>
    :root { color-scheme: dark; --bg:#05090f; --panel:#0b1320; --line:#234458; --text:#f4f7fa; --muted:#9eb0bd; --cyan:#36d8d0; --gold:#e8b74c; }
    * { box-sizing: border-box; }
    body { margin:0; min-height:100vh; color:var(--text); background:linear-gradient(180deg,#06111a 0,#03060a 100%); font-family:Arial,"Noto Sans KR",sans-serif; }
    .page { width:min(1180px,100%); margin:auto; padding:22px; }
    header { display:flex; align-items:center; justify-content:space-between; gap:18px; padding:18px 0 22px; border-bottom:1px solid var(--line); }
    .brand { color:var(--cyan); font-size:13px; font-weight:800; letter-spacing:.08em; }
    h1 { margin:7px 0 0; font-size:clamp(27px,4vw,42px); letter-spacing:0; }
    h2 { margin:0 0 16px; font-size:21px; }
    h3 { margin:0 0 8px; font-size:17px; color:var(--gold); }
    p { line-height:1.65; }
    .actions { display:flex; gap:9px; flex-wrap:wrap; }
    .button { min-height:42px; display:inline-flex; align-items:center; justify-content:center; padding:0 16px; border:1px solid var(--line); border-radius:7px; color:var(--text); background:#0b1522; font-weight:700; text-decoration:none; cursor:pointer; }
    .button.primary { color:#031312; background:var(--cyan); border-color:var(--cyan); }
    .status-grid,.source-grid { display:grid; gap:12px; }
    .status-grid { grid-template-columns:repeat(3,minmax(0,1fr)); margin:20px 0; }
    .source-grid { grid-template-columns:repeat(3,minmax(0,1fr)); }
    .card { min-width:0; padding:20px; border:1px solid var(--line); border-radius:8px; background:rgba(10,19,31,.92); }
    .status { display:flex; justify-content:space-between; gap:10px; align-items:center; }
    .status b { color:var(--gold); }
    .status .ready { color:var(--cyan); }
    .summary { margin:0 0 14px; padding:24px; border-color:#3b6e82; }
    .rank { padding:12px 0; border-top:1px solid rgba(80,119,139,.45); }
    .rank:first-of-type { border-top:0; padding-top:0; }
    .rank strong { display:block; margin-bottom:4px; }
    .meta,.empty,.notice { color:var(--muted); }
    ul { margin:8px 0 0; padding-left:20px; line-height:1.65; }
    .notice { margin-top:16px; padding:16px 18px; border-left:3px solid var(--gold); background:#0a1018; font-size:14px; }
    .missing-link { color:var(--cyan); }
    @media (max-width:850px) { .source-grid { grid-template-columns:1fr; } }
    @media (max-width:650px) { .page{padding:12px} header{align-items:stretch;flex-direction:column}.actions,.actions>*{width:100%}.status-grid{grid-template-columns:1fr} }
    @media print { body{background:#fff;color:#111}.actions{display:none}.card{background:#fff;border-color:#aaa}.meta,.empty,.notice{color:#444} }
  </style>
</head>
<body>
  <main class="page">
    <header>
      <div><div class="brand">IRIS MAPPING LAB</div><h1>최종 종합 판독</h1></div>
      <nav class="actions">
        <a class="button" href="reading.html">홍채 판독 결과</a>
        <a class="button" href="index.html">메인 화면</a>
        <button class="button primary" type="button" onclick="window.print()">저장/인쇄</button>
      </nav>
    </header>

    <section id="sourceStatus" class="status-grid" aria-label="자료 준비 상태"></section>
    <section class="card summary"><h2>세 자료 종합 참고</h2><div id="combinedSummary"></div></section>
    <section class="source-grid">
      <article class="card"><h2>홍채 관찰 요약</h2><div id="irisSummary"></div></article>
      <article class="card"><h2>건강 체크문진 요약</h2><div id="healthSummary"></div></article>
      <article class="card"><h2>AI 보험상담 요약</h2><div id="insuranceSummary"></div></article>
    </section>
    <p class="notice">본 화면은 상담 순서를 정리하는 참고자료입니다. 홍채 관찰은 의학적으로 확립된 진단 검사가 아니며, 건강문진은 의료진의 진단과 치료를 대체하지 않습니다. 보험상담 결과 역시 가입 가능 여부나 특정 상품의 적합성을 확정하지 않습니다.</p>
  </main>
  <script>
    const sessionPhone = normalizePhone(localStorage.getItem("irisMappingSession"));
    const iris = readJson("irisReadingResult");
    const health = sessionPhone ? readJson(`irisHealthTest:${sessionPhone}`) : null;
    const insurance = sessionPhone ? readJson(`irisAiInsuranceConsult_${sessionPhone}`) : null;
    const irisForAccount = iris && (!iris.accountPhone || normalizePhone(iris.accountPhone) === sessionPhone) ? iris : null;

    function normalizePhone(value) { let digits=String(value||"").replace(/\D/g,""); if(digits.length===10&&digits.startsWith("10")) digits=`0${digits}`; return digits; }
    function readJson(key) { try { return JSON.parse(localStorage.getItem(key)||"null"); } catch (_) { return null; } }
    function escapeHtml(value) { return String(value??"").replace(/[&<>"']/g,(char)=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[char])); }
    function list(value) { return Array.isArray(value) ? value.filter(Boolean).join(", ") : (value || "미기록"); }
    function isMeaningful(value) {
      if (Array.isArray(value)) return value.some(isMeaningful);
      const text=String(value??"").trim();
      if (!text) return false;
      return !["아니오","전혀 아니다","없음","해당 없음","정상","모름","잘 모름","미기록","특별히 없음","통증 없음","환경노출 없음","알레르기 없음"].includes(text);
    }

    const irisTop = buildIrisSummary(irisForAccount);
    const healthTop = buildHealthSummary(health);
    const insuranceTop = buildInsuranceSummary(insurance);
    renderStatus();
    renderCombined();

    function buildIrisSummary(data) {
      const target=document.querySelector("#irisSummary");
      if (!data) { target.innerHTML='<p class="empty">현재 계정의 홍채 판독 결과가 없습니다.</p><a class="missing-link" href="index.html">홍채 판독하러 가기</a>'; return []; }
      const grouped={};
      [["우안",data.right||[]],["좌안",data.left||[]]].forEach(([eye,items])=>items.forEach((item)=>{
        const key=item.area||item.code||"미분류";
        grouped[key] ||= {area:key,score:0,eyes:new Set(),consultation:item.consultation||item.dbConsultation||"상담 시 참고합니다."};
        grouped[key].score += Number(item.priorityScore||item.score||0); grouped[key].eyes.add(eye);
      }));
      const top=Object.values(grouped).map((item)=>({...item,score:item.score+(item.eyes.size>1?5:0)})).sort((a,b)=>b.score-a.score).slice(0,3);
      const collarette=data.collarette||{};
      const collaretteText=[collarette.right?.consultation,collarette.left?.consultation].filter(Boolean).join(" / ") || "꽃모양 영역 기록 없음";
      target.innerHTML = top.map((item,index)=>`<div class="rank"><h3>${index+1}순위 · ${escapeHtml(item.area)}</h3><strong>${[...item.eyes].join("·")}</strong><span class="meta">${escapeHtml(item.consultation)}</span></div>`).join("") + `<p class="meta"><strong>좌우 꽃모양 영역 종합:</strong> ${escapeHtml(collaretteText)}</p>`;
      return top;
    }

    function buildHealthSummary(data) {
      const target=document.querySelector("#healthSummary");
      if (!data) { target.innerHTML='<p class="empty">저장된 건강 체크문진이 없습니다.</p><a class="missing-link" href="health.html">건강 체크문진 작성하기</a>'; return []; }
      const names={familyHistory:"가족력·과거력",lifestyle:"생활리듬·수면",diet:"식습관·섭취",stress:"스트레스 원인",personality:"성격·감정 반응",occupation:"직업환경",riskEnvironment:"사고·환경 노출",symptoms:"현재 증상",healthAwareness:"건강 관심도",foodSafetyAwareness:"식품 안전 인식",environmentalExposureAwareness:"환경 노출 인식",cookingStorageHabits:"조리·보관 습관",supplementUse:"건강식품 섭취"};
      const meta=new Set(["phone","status","updatedAt","createdAt","answerLabels"]); const labels=data.answerLabels||{};
      const groups=Object.entries(data).filter(([key,value])=>!meta.has(key)&&value&&typeof value==="object"&&!Array.isArray(value)).map(([key,answers])=>{
        const findings=Object.entries(answers).filter(([,value])=>isMeaningful(value));
        return {key,title:names[key]||key,count:findings.length,findings};
      }).filter((group)=>group.count).sort((a,b)=>b.count-a.count);
      const top=groups.slice(0,3);
      const details=groups.flatMap((group)=>group.findings.map(([key])=>labels[key])).filter(Boolean).slice(0,7);
      target.innerHTML = top.length ? top.map((group,index)=>`<div class="rank"><h3>${index+1}순위 · ${escapeHtml(group.title)}</h3><span class="meta">확인 항목 ${group.count}개</span></div>`).join("") + (details.length?`<strong>주요 확인 문항</strong><ul>${details.map((text)=>`<li>${escapeHtml(text)}</li>`).join("")}</ul>`:"") : '<p class="empty">두드러진 체크 항목이 없습니다.</p>';
      return top;
    }

    function buildInsuranceSummary(data) {
      const target=document.querySelector("#insuranceSummary");
      if (!data) { target.innerHTML='<p class="empty">저장된 AI 보험상담이 없습니다.</p><a class="missing-link" href="ai-health.html">보험상담 작성하기</a>'; return []; }
      const answers=data.answers||{}; const recs=Array.isArray(data.recommendation)?data.recommendation:[];
      target.innerHTML=`<p><strong>걱정 대상:</strong> ${escapeHtml(list(answers.worryTarget))}<br><strong>주요 걱정:</strong> ${escapeHtml(list(answers.personalRiskConcern))}<br><strong>현재 보험:</strong> ${escapeHtml(list(answers.currentInsurance))}<br><strong>예산:</strong> ${escapeHtml(list(answers.budget))}</p>` + (recs.length?recs.slice(0,5).map((item,index)=>`<div class="rank"><h3>${index+1}순위 · ${escapeHtml(item.title)}</h3><span class="meta">${escapeHtml(item.reason)}</span></div>`).join(""):'<p class="empty">상담 우선순위가 아직 생성되지 않았습니다.</p>');
      return recs;
    }

    function renderStatus() {
      const items=[["홍채 판독",!!irisForAccount],["건강 체크문진",!!health],["AI 보험상담",!!insurance]];
      document.querySelector("#sourceStatus").innerHTML=items.map(([name,ready])=>`<div class="card status"><strong>${name}</strong><b class="${ready?"ready":""}">${ready?"준비 완료":"자료 없음"}</b></div>`).join("");
    }

    function renderCombined() {
      const parts=[];
      if (irisTop.length) parts.push(`홍채 관찰에서는 <strong>${escapeHtml(irisTop.map((item)=>item.area).join(", "))}</strong> 영역이 우선 확인됩니다.`);
      if (healthTop.length) parts.push(`건강문진에서는 <strong>${escapeHtml(healthTop.map((item)=>item.title).join(", "))}</strong> 관련 응답이 상대적으로 많이 확인됩니다.`);
      if (insuranceTop.length) parts.push(`보험상담에서는 <strong>${escapeHtml(insuranceTop.slice(0,3).map((item)=>item.title).join(", "))}</strong> 순서로 점검 방향이 정리됩니다.`);
      if (!sessionPhone) parts.push('로그인 계정을 확인할 수 없어 계정별 문진과 보험상담을 불러오지 못했습니다.');
      if (!parts.length) parts.push('종합할 저장 자료가 없습니다. 세 항목을 먼저 진행해 주세요.');
      parts.push('세 결과가 서로 일치한다고 단정하지 않으며, 현재 상담에서 무엇을 먼저 확인할지 정하는 참고자료로만 사용합니다.');
      document.querySelector("#combinedSummary").innerHTML=parts.map((text)=>`<p>${text}</p>`).join("");
    }
  </script>
</body>
</html>
