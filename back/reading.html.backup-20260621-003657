<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>홍채 판독 결과</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #050711;
      --panel: rgba(12, 17, 31, 0.94);
      --line: rgba(76, 210, 200, 0.24);
      --ink: #f7f4ec;
      --muted: rgba(247, 244, 236, 0.68);
      --accent: #3ad4c7;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at 18% 0%, rgba(58, 212, 199, 0.16), transparent 26%),
        var(--bg);
      color: var(--ink);
      font-family: "Segoe UI", "Noto Sans KR", Arial, sans-serif;
    }

    .page {
      display: grid;
      gap: 16px;
      margin: 0 auto;
      max-width: 900px;
      padding: 24px;
    }

    header,
    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 10px;
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.34);
    }

    header {
      align-items: center;
      display: flex;
      gap: 16px;
      justify-content: space-between;
      padding: 18px 20px;
    }

    h1,
    h2,
    p {
      margin: 0;
    }

    h1 {
      font-size: 28px;
    }

    h2 {
      font-size: 20px;
    }

    .sub {
      color: var(--muted);
      margin-top: 8px;
    }

    .actions {
      display: flex;
      gap: 8px;
    }

    button,
    a.button {
      align-items: center;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--line);
      border-radius: 8px;
      color: var(--ink);
      cursor: pointer;
      display: inline-flex;
      font: inherit;
      font-weight: 800;
      justify-content: center;
      min-height: 40px;
      padding: 0 14px;
      text-decoration: none;
    }

    .primary {
      background: linear-gradient(135deg, #35d7c6, #7040c9);
      border: 0;
    }

    .result-grid {
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    }

    .card {
      display: grid;
      gap: 14px;
      padding: 18px;
    }

    .reading-list {
      color: var(--muted);
      display: grid;
      gap: 8px;
      line-height: 1.5;
      margin: 0;
      padding-left: 20px;
    }

    .reading-list strong {
      color: var(--ink);
    }

    .observation-rank {
      border-top: 1px solid var(--line);
      display: grid;
      gap: 8px;
      padding: 14px 0;
    }

    .observation-rank:first-child {
      border-top: 0;
      padding-top: 0;
    }

    .observation-rank h3 {
      color: var(--accent);
      font-size: 17px;
      margin: 0;
    }

    .observation-rank dl {
      display: grid;
      gap: 6px;
      grid-template-columns: 76px 1fr;
      margin: 0;
    }

    .observation-rank dt {
      color: var(--muted);
      font-weight: 700;
    }

    .observation-rank dd {
      line-height: 1.55;
      margin: 0;
    }

    .eye-summary,
    .collarette-note,
    .notice {
      background: rgba(58, 212, 199, 0.06);
      border: 1px solid var(--line);
      border-radius: 8px;
      line-height: 1.65;
      padding: 14px;
    }

    .eye-summary strong,
    .collarette-note strong {
      color: var(--accent);
      display: block;
      margin-bottom: 4px;
    }

    .notice {
      color: var(--muted);
      font-size: 14px;
      grid-column: 1 / -1;
    }

    .empty {
      color: var(--muted);
      padding: 18px 0;
    }

    @media (max-width: 640px) {
      .page {
        padding: 10px;
      }

      header {
        align-items: stretch;
        flex-direction: column;
      }

      .actions,
      .actions > * {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <header>
      <div>
        <h1>홍채 판독 결과</h1>
        <p id="createdAt" class="sub">판독 결과를 불러오는 중입니다.</p>
      </div>
      <div class="actions">
        <a class="button" href="index.html">맵핑 화면</a>
        <a class="button" href="index.html">메인 화면</a>
        <button class="primary" type="button" onclick="window.print()">저장/인쇄</button>
      </div>
    </header>

    <section class="result-grid">
      <article class="card">
        <h2>우안 관찰 결과</h2>
        <div id="rightResults"></div>
      </article>
      <article class="card">
        <h2>좌안 관찰 결과</h2>
        <div id="leftResults"></div>
      </article>
      <p class="notice">본 결과는 홍채 사진에서 관찰되는 모양과 위치를 전통적 홍채지도에 대응한 상담 참고 자료이며, 의학적 진단이나 치료를 대신하지 않습니다.</p>
    </section>
  </main>

  <script>
    const raw = localStorage.getItem("irisReadingResult");
    const data = raw ? JSON.parse(raw) : null;

    function escapeHtml(value) {
      return String(value ?? "").replace(/[&<>"']/g, (character) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;"
      })[character]);
    }

    function buildEyeSummary(results) {
      if (!results || results.length === 0) return "관찰된 우선 영역이 없습니다.";
      const areas = results.map((item) => item.area).filter(Boolean);
      if (areas.length === 1) return `이 홍채에서는 ${areas[0]} 관련 영역이 가장 먼저 보입니다.`;
      if (areas.length === 2) return `이 홍채에서는 ${areas[0]} 관련 영역이 가장 먼저 보이고, 그다음 ${areas[1]} 관련 영역이 체크됩니다.`;
      return `이 홍채에서는 ${areas[0]} 관련 영역이 가장 먼저 보이고, 그다음 ${areas[1]}, ${areas[2]} 관련 영역 순서로 체크됩니다. ${areas[2]} 관련 영역은 참고 수준으로 보입니다.`;
    }

    function renderReadingList(results, collarette) {
      if (!results || results.length === 0) {
        return '<p class="empty">판독 결과가 없습니다.</p>';
      }

      return `
        <div class="observation-list">
          ${results.slice(0, 3).map((item, index) => `
            <section class="observation-rank">
              <h3>${index + 1}순위</h3>
              <dl>
                <dt>영역코드</dt><dd>${escapeHtml(item.code)}</dd>
                <dt>부위</dt><dd>${escapeHtml(item.area)}</dd>
                <dt>상담표현</dt><dd>${escapeHtml(item.consultation)}</dd>
              </dl>
            </section>
          `).join("")}
        </div>
        <p class="eye-summary"><strong>최종 요약</strong>${escapeHtml(buildEyeSummary(results))}</p>
        ${collarette ? `<p class="collarette-note"><strong>동공 바깥 꽃모양 영역</strong>${escapeHtml(collarette.consultation)}</p>` : ""}
      `;
    }

    if (!data) {
      document.querySelector("#createdAt").textContent = "저장된 판독 결과가 없습니다.";
      document.querySelector("#rightResults").innerHTML = '<p class="empty">결과 없음</p>';
      document.querySelector("#leftResults").innerHTML = '<p class="empty">결과 없음</p>';
    } else {
      document.querySelector("#createdAt").textContent = `판독일시 ${new Date(data.createdAt).toLocaleString("ko-KR")}`;
      document.querySelector("#rightResults").innerHTML = renderReadingList(data.right, data.collarette?.right);
      document.querySelector("#leftResults").innerHTML = renderReadingList(data.left, data.collarette?.left);
    }
  </script>
</body>
</html>
