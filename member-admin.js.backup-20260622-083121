const subscriptions=[];for(let i=0;i<localStorage.length;i++){const key=localStorage.key(i);if(!key||!key.startsWith("irisSubscription:"))continue;try{subscriptions.push({phone:key.split(":")[1],...JSON.parse(localStorage.getItem(key)||"{}")})}catch(_){}}
const escapeMember=(value)=>String(value??"").replace(/[&<>"']/g,(c)=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
const active=subscriptions.filter((item)=>item.status==="관리 중").length;const boxes=subscriptions.filter((item)=>Array.isArray(item.box)&&item.box.length).length;
document.querySelector("#metrics").innerHTML=[["전체 구독 기록",subscriptions.length],["관리 중",active],["건강박스 구성",boxes]].map(([label,value])=>'<div class="metric"><strong>'+escapeMember(label)+'</strong><p>'+escapeMember(value)+'</p></div>').join("");
document.querySelector("#rows").innerHTML=subscriptions.length?subscriptions.map((item)=>'<tr><td>'+escapeMember(item.phone)+'</td><td>'+escapeMember(item.status||"미등록")+'</td><td>'+escapeMember(item.plan||"-")+'</td><td>'+escapeMember(item.healthType||"-")+'</td><td>'+escapeMember(item.months||0)+'개월</td><td>'+escapeMember((item.box||[]).join(", ")||"-")+'</td><td>'+escapeMember(item.updatedAt?new Date(item.updatedAt).toLocaleString("ko-KR"):"-")+'</td></tr>').join(""):'<tr><td colspan="7" class="muted">저장된 구독 회원이 없습니다.</td></tr>';
